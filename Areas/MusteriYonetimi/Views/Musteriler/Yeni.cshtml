@model PazarCep.Areas.MusteriYonetimi.Models.MusteriKayitFormViewModel
@{
    ViewData["Title"] = "Yeni Musteri";
}

<div class="pc-page-shell">
    <section class="pc-page-hero">
        <div class="pc-page-hero__body">
            <span class="pc-page-eyebrow">CRM / Onboarding</span>
            <h1 class="pc-page-title">Yeni musteri taslagi</h1>
            <p class="pc-page-description mb-0">Temel hesap bilgisini, operasyon sahibini ve ilk iletisim baglamini tek bir kayit akisinda toplayin.</p>

            <div class="pc-page-actions mt-4">
                <a asp-area="MusteriYonetimi" asp-controller="Musteriler" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bx bx-arrow-back me-1"></i>Musteri listesine don
                </a>
            </div>
        </div>
    </section>

    <section class="row g-4">
        <div class="col-12 col-xl-8">
            <div class="pc-panel">
                <div class="pc-panel__header">
                    <div>
                        <h2 class="pc-panel__title">Kayit formu</h2>
                        <p class="pc-panel__subtitle mb-0">Sadece gerekli alanlar istenir; geri kalan detay musteri calisma alaninda tamamlanir.</p>
                    </div>
                </div>
                <div class="pc-panel__body">
                    <form asp-area="MusteriYonetimi" asp-controller="Musteriler" asp-action="Yeni" method="post" class="pc-page-stack">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="pc-filter-grid">
                            <div class="pc-col-6">
                                <label asp-for="AdSoyadUnvan" class="form-label"></label>
                                <input asp-for="AdSoyadUnvan" class="form-control" />
                                <span asp-validation-for="AdSoyadUnvan" class="text-danger"></span>
                            </div>
                            <div class="pc-col-6">
                                <label asp-for="Sirket" class="form-label"></label>
                                <input asp-for="Sirket" class="form-control" />
                                <span asp-validation-for="Sirket" class="text-danger"></span>
                            </div>
                            <div class="pc-col-4">
                                <label asp-for="Telefon" class="form-label"></label>
                                <input asp-for="Telefon" class="form-control" />
                                <span asp-validation-for="Telefon" class="text-danger"></span>
                            </div>
                            <div class="pc-col-4">
                                <label asp-for="Eposta" class="form-label"></label>
                                <input asp-for="Eposta" class="form-control" />
                                <span asp-validation-for="Eposta" class="text-danger"></span>
                            </div>
                            <div class="pc-col-4">
                                <label asp-for="Temsilci" class="form-label"></label>
                                <input asp-for="Temsilci" class="form-control" />
                                <span asp-validation-for="Temsilci" class="text-danger"></span>
                            </div>
                            <div class="pc-col-6">
                                <label asp-for="Segment" class="form-label"></label>
                                <select asp-for="Segment" class="form-select">
                                    <option>Kurumsal</option>
                                    <option>Sadik Perakende</option>
                                    <option>Yeni Kazanim</option>
                                    <option>Bolgesel Zincir</option>
                                </select>
                                <span asp-validation-for="Segment" class="text-danger"></span>
                            </div>
                            <div class="pc-col-6">
                                <label asp-for="Adres" class="form-label"></label>
                                <input asp-for="Adres" class="form-control" />
                                <span asp-validation-for="Adres" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-check">
                            <input asp-for="AktifMi" class="form-check-input" />
                            <label asp-for="AktifMi" class="form-check-label"></label>
                        </div>

                        <div class="pc-inline-actions">
                            <button type="submit" class="btn btn-primary">
                                <i class="bx bx-save me-1"></i>Taslagi kaydet
                            </button>
                            <a asp-area="MusteriYonetimi" asp-controller="Musteriler" asp-action="Index" class="btn btn-outline-secondary">Iptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="pc-panel h-100">
                <div class="pc-panel__header">
                    <div>
                        <h2 class="pc-panel__title">Onboarding kontrolu</h2>
                        <p class="pc-panel__subtitle mb-0">Kayit sonrasinda tamamlancak temel adimlar.</p>
                    </div>
                </div>
                <div class="pc-panel__body">
                    <div class="pc-health-list">
                        <article class="pc-health-list__item">
                            <div>
                                <div class="fw-semibold mb-1">1. Temel profil</div>
                                <p class="text-muted mb-0">Musteri kodu, temsilci ve segment olusturulur.</p>
                            </div>
                            <span class="pc-status-pill pc-status-pill--success">Bu form</span>
                        </article>
                        <article class="pc-health-list__item">
                            <div>
                                <div class="fw-semibold mb-1">2. Fatura ve adres</div>
                                <p class="text-muted mb-0">ETicaret musteri alaninda detayli adres ve muhasebe profili tamamlanir.</p>
                            </div>
                            <span class="pc-status-pill pc-status-pill--info">Sonraki adim</span>
                        </article>
                        <article class="pc-health-list__item">
                            <div>
                                <div class="fw-semibold mb-1">3. Ilk siparis ve bildirim</div>
                                <p class="text-muted mb-0">Randevu, siparis ve bildirim tercihleri devreye alinir.</p>
                            </div>
                            <span class="pc-status-pill pc-status-pill--warning">Takip</span>
                        </article>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@section PageScripts {
    <partial name="_ValidationScriptsPartial" />
}
