@model PazarCep.Areas.Lojistik.Models.LojistikPanoVM
@{
    ViewData["Title"] = ViewData["Title"] ?? "Lojistik - Kontrol Paneli";
}

<div class="row g-4">
    <div class="col-12">
        <div class="card">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="mb-1">@ViewData["Title"]</h5>
                    <small class="text-muted">Araç ve sevkiyat durumlarını buradan takip edebilirsin.</small>
                </div>
                <a asp-area="Lojistik" asp-controller="Filo" asp-action="Index" class="btn btn-primary">
                    Filoya Git
                </a>
            </div>
        </div>
    </div>

    <!-- KPI -->
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold">Toplam Araç</div>
                <div class="fs-3">@Model.ToplamArac</div>
                <small class="text-muted">Müsait: @Model.MusaitArac</small>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold">Sevkiyatta</div>
                <div class="fs-3">@Model.SevkiyattaArac</div>
                <small class="text-muted">Yolda olan araçlar</small>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold">Serviste</div>
                <div class="fs-3">@Model.ServisteArac</div>
                <small class="text-muted">Bakım / onarım</small>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold">Bugünkü Sevkiyat</div>
                <div class="fs-3">@Model.BugunkuSevkiyat</div>
                <small class="text-muted">Bekleyen: @Model.BekleyenSevkiyat</small>
            </div>
        </div>
    </div>

    <!-- Son sevkiyatlar -->
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Son Sevkiyatlar</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Sevkiyat No</th>
                                <th>Çıkış</th>
                                <th>Varış</th>
                                <th>Araç</th>
                                <th>Durum</th>
                                <th>Tarih</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var x in Model.SonSevkiyatlar)
                            {
                                <tr>
                                    <td>@x.SevkiyatNo</td>
                                    <td>@x.Cikis</td>
                                    <td>@x.Varis</td>
                                    <td>@x.AracPlaka</td>
                                    <td>@x.Durum</td>
                                    <td>@x.Tarih.ToString("dd.MM.yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
