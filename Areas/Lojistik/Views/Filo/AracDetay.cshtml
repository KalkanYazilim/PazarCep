@model PazarCep.Areas.Lojistik.Models.AracDetayVM
@{
    ViewData["Title"] = ViewData["Title"] ?? "Araç Detayı";
}

<div class="row g-4">
    <div class="col-12">
        <div class="card">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="mb-1">@Model.Plaka</h5>
                    <small class="text-muted">@Model.AracTipi • Sürücü: @Model.Surucu</small>
                </div>
                <a asp-area="Lojistik" asp-controller="Filo" asp-action="Index" class="btn btn-label-secondary">
                    Filoya Dön
                </a>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold">Durum</div>
                <div class="fs-4">@Model.Durum</div>
                <small class="text-muted">Son güncelleme: @Model.SonGuncelleme.ToString("dd.MM.yyyy HH:mm")</small>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold">Konum</div>
                <div class="fs-4">@Model.Konum</div>
                <small class="text-muted">Takip entegrasyonu eklenebilir (GPS)</small>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold">Bugünkü Sevkiyat</div>
                <div class="fs-3">@Model.BugunkuSevkiyatAdedi</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold">Bugünkü Km</div>
                <div class="fs-3">@Model.BugunkuKm</div>
            </div>
        </div>
    </div>
</div>
