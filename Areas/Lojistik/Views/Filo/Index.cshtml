@model List<PazarCep.Areas.Lojistik.Models.AracListeSatiriVM>
@{
    ViewData["Title"] = ViewData["Title"] ?? "Filo Yönetimi";
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="mb-0">@ViewData["Title"]</h5>
        <a asp-area="Lojistik" asp-controller="AnaSayfa" asp-action="Index" class="btn btn-label-secondary">
            Kontrol Paneli
        </a>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Plaka</th>
                        <th>Araç Tipi</th>
                        <th>Sürücü</th>
                        <th>Durum</th>
                        <th>Konum</th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var x in Model)
                    {
                        <tr>
                            <td>@x.Plaka</td>
                            <td>@x.AracTipi</td>
                            <td>@x.Surucu</td>
                            <td>@x.Durum</td>
                            <td>@x.Konum</td>
                            <td class="text-end">
                                <a asp-area="Lojistik" asp-controller="Filo" asp-action="AracDetay" asp-route-id="@x.Id"
                                   class="btn btn-sm btn-primary">
                                    Detay
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
