@model AppointmentBoardPageViewModel
@{
    ViewData["Title"] = "Randevu Planlama";
}

<div class="pc-page-shell">
    <section class="pc-page-hero">
        <div class="pc-page-hero__body">
            <span class="pc-page-eyebrow">E-Ticaret / Randevu</span>
            <h1 class="pc-page-title">@Model.Baslik</h1>
            <p class="pc-page-description mb-0">@Model.Aciklama</p>
            <div class="pc-page-actions mt-4">
                <a asp-area="ETicaret" asp-controller="Emir" asp-action="SiparisListesi" class="btn btn-outline-secondary">
                    <i class="bx bx-package me-1"></i>Siparişlere dön
                </a>
                <a asp-area="Lojistik" asp-controller="AnaSayfa" asp-action="Index" class="btn btn-primary">
                    <i class="bx bx-car me-1"></i>Lojistik paneli
                </a>
            </div>
        </div>
    </section>

    <section class="pc-kpi-grid">
        @foreach (var kart in Model.OzetKartlar)
        {
            <article class="pc-kpi-card h-100">
                <div class="pc-kpi-card__top">
                    <div>
                        <div class="pc-kpi-card__label">@kart.Baslik</div>
                        <div class="pc-kpi-card__value">@kart.Deger</div>
                    </div>
                    <span class="pc-kpi-card__icon"><i class="bx @kart.Ikon"></i></span>
                </div>
                <div class="pc-kpi-card__meta">@kart.Aciklama</div>
            </article>
        }
    </section>

    <section class="row g-4">
        <div class="col-12 col-xl-5">
            <div class="pc-panel h-100">
                <div class="pc-panel__header">
                    <div>
                        <h2 class="pc-panel__title">Slot kapasitesi</h2>
                        <p class="pc-panel__subtitle mb-0">Saatlik doluluk ve onay durumu görünümü.</p>
                    </div>
                </div>
                <div class="pc-panel__body">
                    <div class="pc-health-list">
                        @foreach (var slot in Model.Slotlar)
                        {
                            <article class="pc-health-list__item">
                                <div>
                                    <div class="fw-semibold mb-1">@slot.SaatAraligi · @slot.Baslik</div>
                                    <p class="text-muted mb-1">@slot.Konum</p>
                                    <small class="text-muted">@slot.Doluluk</small>
                                </div>
                                <span class="pc-status-pill pc-status-pill--@slot.Ton">@slot.Durum</span>
                            </article>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-7">
            <div class="pc-panel pc-table-card h-100">
                <div class="pc-panel__header">
                    <div>
                        <h2 class="pc-panel__title">Randevu kayıtları</h2>
                        <p class="pc-panel__subtitle mb-0">Sipariş, müşteri ve konum bağlamıyla okunabilir plan tablosu.</p>
                    </div>
                </div>
                <div class="pc-panel__body d-none d-lg-block">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Kod</th>
                                    <th>Tip</th>
                                    <th>Müşteri</th>
                                    <th>Zaman</th>
                                    <th>Konum</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kayit in Model.Kayitlar)
                                {
                                    <tr>
                                        <td class="fw-semibold">@kayit.Kod</td>
                                        <td>@kayit.Tip</td>
                                        <td>
                                            <div class="d-flex flex-column">
                                                <span>@kayit.Musteri</span>
                                                <small class="text-muted">@kayit.Ozet</small>
                                            </div>
                                        </td>
                                        <td>@kayit.Zaman</td>
                                        <td>@kayit.Konum</td>
                                        <td><span class="pc-status-pill pc-status-pill--@kayit.Ton">@kayit.Durum</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="pc-panel__body d-lg-none">
                    <div class="pc-mobile-list">
                        @foreach (var kayit in Model.Kayitlar)
                        {
                            <article class="pc-mobile-card">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                    <div>
                                        <div class="fw-semibold">@kayit.Kod · @kayit.Tip</div>
                                        <div class="text-muted">@kayit.Musteri</div>
                                    </div>
                                    <span class="pc-status-pill pc-status-pill--@kayit.Ton">@kayit.Durum</span>
                                </div>
                                <p class="text-muted mb-3">@kayit.Ozet</p>
                                <div class="pc-mobile-card__grid">
                                    <div>
                                        <span class="pc-mobile-card__label">Zaman</span>
                                        <strong>@kayit.Zaman</strong>
                                    </div>
                                    <div>
                                        <span class="pc-mobile-card__label">Konum</span>
                                        <strong>@kayit.Konum</strong>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
