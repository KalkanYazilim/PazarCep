@model MusteriBildirimlerSayfaViewModel
@{
    ViewData["Title"] = "Müşteri - Bildirimler";
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/customer-workspace.css" />
}

<div class="customer-workspace">
    @await Html.PartialAsync("_MusteriDetayKabugu", Model)

    @await Html.PartialAsync("_MusteriOzetKartlari", Model.KanalKartlari)

    <div class="alert alert-light border mb-0">
        Bildirim tercihleri operasyonel görünüm olarak sunulur. Kalıcı değişiklikler hesap sahibi ve temsilci onayıyla uygulanır.
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-8">
            @for (var grupIndex = 0; grupIndex < Model.TercihGruplari.Count; grupIndex++)
            {
                var grup = Model.TercihGruplari[grupIndex];

                <div class="card customer-section-card border-0 @(grupIndex == Model.TercihGruplari.Count - 1 ? string.Empty : "mb-4")">
                    <div class="card-header border-0 pb-0">
                        <h5 class="mb-1">@grup.Baslik</h5>
                        <p class="text-muted mb-0">@grup.Aciklama</p>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive d-none d-lg-block">
                            <table class="table align-middle mb-0 customer-preference-table">
                                <thead>
                                    <tr>
                                        <th>Akış</th>
                                        <th class="text-center">E-posta</th>
                                        <th class="text-center">SMS</th>
                                        <th class="text-center">Push</th>
                                        <th class="text-center">Uygulama</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (var tercihIndex = 0; tercihIndex < grup.Tercihler.Count; tercihIndex++)
                                    {
                                        var tercih = grup.Tercihler[tercihIndex];
                                        var prefix = $"notification_{grupIndex}_{tercihIndex}";

                                        <tr>
                                            <td>
                                                <div class="d-flex flex-column">
                                                    <strong>@tercih.Baslik</strong>
                                                    <small class="text-muted">@tercih.Aciklama</small>
                                                </div>
                                            </td>
                                            <td class="text-center"><input id="@(prefix)_email" name="@(prefix)_email" class="form-check-input" type="checkbox" checked="@tercih.Eposta" disabled aria-label="@($"{tercih.Baslik} e-posta bildirimi")" /></td>
                                            <td class="text-center"><input id="@(prefix)_sms" name="@(prefix)_sms" class="form-check-input" type="checkbox" checked="@tercih.Sms" disabled aria-label="@($"{tercih.Baslik} SMS bildirimi")" /></td>
                                            <td class="text-center"><input id="@(prefix)_push" name="@(prefix)_push" class="form-check-input" type="checkbox" checked="@tercih.Push" disabled aria-label="@($"{tercih.Baslik} push bildirimi")" /></td>
                                            <td class="text-center"><input id="@(prefix)_app" name="@(prefix)_app" class="form-check-input" type="checkbox" checked="@tercih.Uygulama" disabled aria-label="@($"{tercih.Baslik} uygulama bildirimi")" /></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="row g-3 d-lg-none">
                            @for (var tercihIndex = 0; tercihIndex < grup.Tercihler.Count; tercihIndex++)
                            {
                                var tercih = grup.Tercihler[tercihIndex];
                                var prefix = $"notificationMobile_{grupIndex}_{tercihIndex}";

                                <div class="col-12">
                                    <div class="customer-mobile-card card border-0">
                                        <div class="card-body">
                                            <strong>@tercih.Baslik</strong>
                                            <p class="text-muted mb-3">@tercih.Aciklama</p>
                                            <div class="customer-toggle-grid">
                                                <label for="@(prefix)_email"><input id="@(prefix)_email" name="@(prefix)_email" class="form-check-input" type="checkbox" checked="@tercih.Eposta" disabled /> E-posta</label>
                                                <label for="@(prefix)_sms"><input id="@(prefix)_sms" name="@(prefix)_sms" class="form-check-input" type="checkbox" checked="@tercih.Sms" disabled /> SMS</label>
                                                <label for="@(prefix)_push"><input id="@(prefix)_push" name="@(prefix)_push" class="form-check-input" type="checkbox" checked="@tercih.Push" disabled /> Push</label>
                                                <label for="@(prefix)_app"><input id="@(prefix)_app" name="@(prefix)_app" class="form-check-input" type="checkbox" checked="@tercih.Uygulama" disabled /> Uygulama</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="col-12 col-xl-4">
            <div class="card customer-section-card border-0">
                <div class="card-header border-0 pb-0">
                    <h5 class="mb-1">Son bildirim geçmişi</h5>
                    <p class="text-muted mb-0">Kanal, teslim durumu ve özet bilgi.</p>
                </div>
                <div class="card-body">
                    <div class="customer-stack-list">
                        @foreach (var kayit in Model.SonBildirimler)
                        {
                            <div class="customer-stack-list__item">
                                <div>
                                    <div class="d-flex gap-2 align-items-center mb-1">
                                        <strong>@kayit.Baslik</strong>
                                        <span class="badge bg-label-@kayit.DurumSinifi">@kayit.Durum</span>
                                    </div>
                                    <p class="text-muted mb-1">@kayit.Kanal · @kayit.Tarih</p>
                                    <small>@kayit.Ozet</small>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
