@model CategoryManagementPageViewModel
@{
    ViewData["Title"] = "Kategori Yönetimi";
}

<div class="pc-page-shell">
    <section class="pc-page-hero">
        <div class="pc-page-hero__body">
            <span class="pc-page-eyebrow">E-Ticaret / Kategori</span>
            <h1 class="pc-page-title">@Model.Baslik</h1>
            <p class="pc-page-description mb-0">@Model.Aciklama</p>
            <div class="pc-page-actions mt-4">
                <a asp-area="ETicaret" asp-controller="Urunler" asp-action="Liste" class="btn btn-outline-secondary">
                    <i class="bx bx-arrow-back me-1"></i>Kataloğa dön
                </a>
                <a asp-area="ETicaret" asp-controller="Urunler" asp-action="Ekle" class="btn btn-primary">
                    <i class="bx bx-plus me-1"></i>Yeni ürün ekle
                </a>
            </div>
        </div>
    </section>

    <section class="pc-kpi-grid">
        @foreach (var kart in Model.OzetKartlar)
        {
            <article class="pc-kpi-card h-100">
                <div class="pc-kpi-card__top">
                    <div>
                        <div class="pc-kpi-card__label">@kart.Baslik</div>
                        <div class="pc-kpi-card__value">@kart.Deger</div>
                    </div>
                    <span class="pc-kpi-card__icon"><i class="bx @kart.Ikon"></i></span>
                </div>
                <div class="pc-kpi-card__meta">@kart.Aciklama</div>
            </article>
        }
    </section>

    <section class="pc-module-grid">
        @foreach (var kategori in Model.Kategoriler)
        {
            <article class="pc-module-card">
                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                    <div>
                        <h2 class="h6 mb-1">@kategori.Ad</h2>
                        <p class="text-muted mb-0">@kategori.Aciklama</p>
                    </div>
                    <span class="pc-status-pill pc-status-pill--@kategori.DurumTonu">@kategori.Durum</span>
                </div>
                <div class="pc-mobile-card__grid">
                    <div>
                        <span class="pc-mobile-card__label">Ürün sayısı</span>
                        <strong>@kategori.UrunSayisi</strong>
                    </div>
                    <div>
                        <span class="pc-mobile-card__label">Komisyon</span>
                        <strong>@kategori.Komisyon</strong>
                    </div>
                    <div>
                        <span class="pc-mobile-card__label">Sahip</span>
                        <strong>@kategori.Sahip</strong>
                    </div>
                </div>
            </article>
        }
    </section>
</div>
