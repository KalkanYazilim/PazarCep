@model PazarCep.Areas.Egitim.Models.EgitimKursListeSayfaViewModel
@{
    ViewData["Title"] = "Kurslarım";
}

<div class="pc-page-shell">
    <section class="pc-page-hero">
        <div class="pc-page-hero__body">
            <span class="pc-page-eyebrow">Eğitim / Kurslar</span>
            <h1 class="pc-page-title">@Model.Baslik</h1>
            <p class="pc-page-description mb-0">@Model.Aciklama</p>

            <div class="pc-page-actions mt-4">
                <a asp-area="Egitim" asp-controller="AnaSayfa" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bx bx-arrow-back me-1"></i>Eğitim merkezine dön
                </a>
                <a asp-area="Egitim" asp-controller="Kurs" asp-action="Sertifikalar" class="btn btn-primary">
                    <i class="bx bx-award me-1"></i>Sertifikalar
                </a>
            </div>
        </div>
    </section>

    <section class="pc-kpi-grid">
        @foreach (var kart in Model.OzetKartlar)
        {
            <article class="pc-kpi-card h-100">
                <div class="pc-kpi-card__top">
                    <div>
                        <div class="pc-kpi-card__label">@kart.Baslik</div>
                        <div class="pc-kpi-card__value">@kart.Deger</div>
                    </div>
                    <span class="pc-kpi-card__icon"><i class="bx @kart.Ikon"></i></span>
                </div>
                <div class="pc-kpi-card__meta">@kart.Aciklama</div>
            </article>
        }
    </section>

    <section class="pc-panel">
        <div class="pc-panel__header">
            <div>
                <h2 class="pc-panel__title">Filtre ve görünüm</h2>
                <p class="pc-panel__subtitle mb-0">Kursları seviye, durum ve eğitmen bağlamında tarayın.</p>
            </div>
        </div>
        <div class="pc-panel__body">
            <div class="pc-filter-grid">
                <div class="pc-col-6">
                    <label class="form-label">Kurs ara</label>
                    <input type="text" class="form-control" placeholder="Kurs adı, eğitmen veya konu" />
                </div>
                <div class="pc-col-3">
                    <label class="form-label">Seviye</label>
                    <select class="form-select">
                        <option>Tüm seviyeler</option>
                        <option>Başlangıç</option>
                        <option>Orta</option>
                        <option>İleri</option>
                    </select>
                </div>
                <div class="pc-col-3">
                    <label class="form-label">Durum</label>
                    <select class="form-select">
                        <option>Tüm durumlar</option>
                        <option>Devam Ediyor</option>
                        <option>Beklemede</option>
                        <option>Tamamlandı</option>
                    </select>
                </div>
            </div>
        </div>
    </section>

    <section class="pc-panel pc-table-card">
        <div class="pc-panel__header">
            <div>
                <h2 class="pc-panel__title">Kurs listesi</h2>
                <p class="pc-panel__subtitle mb-0">Masaüstünde yoğun tablo, mobilde öğrenme kartları.</p>
            </div>
        </div>
        <div class="pc-panel__body d-none d-lg-block">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Kurs</th>
                            <th>Seviye</th>
                            <th>Durum</th>
                            <th>Son güncelleme</th>
                            <th>İlerleme</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kurs in Model.Kurslar)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="fw-semibold">@kurs.KursAdi</span>
                                        <span class="text-muted">@kurs.Egitmen</span>
                                        <small class="text-muted">@kurs.Ozet</small>
                                    </div>
                                </td>
                                <td>@kurs.Seviye</td>
                                <td><span class="pc-status-pill pc-status-pill--@kurs.DurumTonu">@kurs.Durum</span></td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span>@kurs.SonGuncelleme</span>
                                        <small class="text-muted">@kurs.Moduller · @kurs.Sure</small>
                                    </div>
                                </td>
                                <td style="min-width: 220px;">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="pc-progress-meter flex-grow-1">
                                            <span style="width:@kurs.IlerlemeYuzde%"></span>
                                        </div>
                                        <strong>@kurs.IlerlemeYuzde%</strong>
                                    </div>
                                    <small class="text-muted">@kurs.IlerlemeMetni</small>
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-area="Egitim" asp-controller="Kurs" asp-action="Detay" asp-route-id="@kurs.Id" class="btn btn-sm btn-primary">Detay</a>
                                        <a asp-area="Egitim" asp-controller="Kurs" asp-action="Icerik" asp-route-id="@kurs.Id" class="btn btn-sm btn-outline-secondary">İçerik</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="pc-panel__body d-lg-none">
            <div class="pc-mobile-list">
                @foreach (var kurs in Model.Kurslar)
                {
                    <article class="pc-mobile-card">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <div class="fw-semibold">@kurs.KursAdi</div>
                                <div class="text-muted">@kurs.Egitmen</div>
                            </div>
                            <span class="pc-status-pill pc-status-pill--@kurs.DurumTonu">@kurs.Durum</span>
                        </div>
                        <p class="text-muted mb-3">@kurs.Ozet</p>
                        <div class="pc-mobile-card__grid mb-3">
                            <div>
                                <span class="pc-mobile-card__label">Seviye</span>
                                <strong>@kurs.Seviye</strong>
                            </div>
                            <div>
                                <span class="pc-mobile-card__label">Süre</span>
                                <strong>@kurs.Sure</strong>
                            </div>
                            <div>
                                <span class="pc-mobile-card__label">Modül</span>
                                <strong>@kurs.Moduller</strong>
                            </div>
                            <div>
                                <span class="pc-mobile-card__label">İlerleme</span>
                                <strong>@kurs.IlerlemeYuzde%</strong>
                            </div>
                        </div>
                        <div class="pc-progress-meter mb-3">
                            <span style="width:@kurs.IlerlemeYuzde%"></span>
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-area="Egitim" asp-controller="Kurs" asp-action="Detay" asp-route-id="@kurs.Id" class="btn btn-primary flex-fill">Detay</a>
                            <a asp-area="Egitim" asp-controller="Kurs" asp-action="Icerik" asp-route-id="@kurs.Id" class="btn btn-outline-secondary flex-fill">İçerik</a>
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>
</div>
