@model List<PazarCep.Areas.Egitim.Models.KursListeSatiriVM>

@if ((TempData["UyariSistemiAktif"] as bool?) == true && TempData["UyariMesaj"] != null)
{
    <div class="alert alert-warning">@TempData["UyariMesaj"]</div>
}


@{
    ViewData["Title"] = "Kurslarım";

    string DurumBadge(string? durum)
    {
        var d = (durum ?? "").Trim().ToLowerInvariant();

        if (d.Contains("tamam"))
            return "bg-label-success";
        if (d.Contains("devam") || d.Contains("aktif"))
            return "bg-label-primary";
        if (d.Contains("bekle"))
            return "bg-label-warning";
        if (d.Contains("pasif") || d.Contains("iptal"))
            return "bg-label-secondary";

        return "bg-label-info";
    }

    string SeviyeBadge(string? seviye)
    {
        var s = (seviye ?? "").Trim().ToLowerInvariant();

        if (s.Contains("baş"))
            return "bg-label-primary";
        if (s.Contains("orta"))
            return "bg-label-warning";
        if (s.Contains("ileri"))
            return "bg-label-danger";

        return "bg-label-secondary";
    }

    int Clamp0_100(int v) => v < 0 ? 0 : (v > 100 ? 100 : v);
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
            <h5 class="mb-1">Kurslarım</h5>
            <div class="text-muted small">
                Toplam <span class="fw-semibold">@Model?.Count</span> kurs
            </div>
        </div>

        <div class="d-flex align-items-center gap-2 flex-wrap">
            <!-- Arama (UI) -->
            <div class="input-group">
                <span class="input-group-text"><i class="bx bx-search"></i></span>
                <input id="kursAra" type="text" class="form-control" placeholder="Kurs ara (ad / eğitmen / durum)" />
            </div>

            <!-- Filtre (UI) -->
            <select id="durumFiltre" class="form-select">
                <option value="">Tüm Durumlar</option>
                <option value="Devam">Devam Ediyor</option>
                <option value="Tamam">Tamamlandı</option>
                <option value="Bekle">Beklemede</option>
            </select>

            <a asp-area="Egitim" asp-controller="Kurs" asp-action="Sertifikalar"
               class="btn btn-outline-primary">
                <i class="bx bx-award me-1"></i>Sertifikalarım
            </a>
        </div>
    </div>

    <div class="card-body">
        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-warning mb-0">
                Henüz görüntülenecek kurs bulunamadı.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle" id="kursTablo">
                    <thead>
                        <tr>
                            <th style="min-width: 240px;">Kurs</th>
                            <th style="min-width: 120px;">Seviye</th>
                            <th style="min-width: 180px;">Eğitmen</th>
                            <th style="min-width: 140px;">Durum</th>
                            <th style="min-width: 240px;">İlerleme</th>
                            <th class="text-end" style="min-width: 220px;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var k in Model)
                        {
                            var yuzde = Clamp0_100(k.IlerlemeYuzde);
                            var durumText = k.Durum ?? "-";
                            var seviyeText = k.Seviye ?? "-";
                            <tr class="kurs-row"
                                data-kurs="@($"{k.KursAdi} {k.Egitmen} {durumText} {seviyeText}".ToLowerInvariant())"
                                data-durum="@durumText.ToLowerInvariant()">
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="fw-semibold">@k.KursAdi</span>
                                        <span class="text-muted small">Kurs ID: @k.Id</span>
                                    </div>
                                </td>

                                <td>
                                    <span class="badge @SeviyeBadge(k.Seviye)">@seviyeText</span>
                                </td>

                                <td>@k.Egitmen</td>

                                <td>
                                    <span class="badge @DurumBadge(k.Durum)">@durumText</span>
                                </td>

                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress w-100" style="height: 8px;">
                                            <div class="progress-bar"
                                                 role="progressbar"
                                                 style="width:@yuzde%"
                                                 aria-valuenow="@yuzde" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <span class="fw-semibold">@yuzde%</span>
                                    </div>
                                    <div class="text-muted small mt-1">
                                        @if (yuzde >= 100)
                                        {
                                            <span>Tamamlandı</span>
                                        }
                                        else if (yuzde == 0)
                                        {
                                            <span>Henüz başlanmadı</span>
                                        }
                                        else
                                        {
                                            <span>Devam ediyor</span>
                                        }
                                    </div>
                                </td>

                                <td class="text-end">
                                    <div class="btn-group">
                                        <a class="btn btn-sm btn-primary"
                                           asp-area="Egitim" asp-controller="Kurs" asp-action="Detay" asp-route-id="@k.Id">
                                            Detay
                                        </a>
                                        <a class="btn btn-sm btn-outline-secondary"
                                           asp-area="Egitim" asp-controller="Kurs" asp-action="Icerik" asp-route-id="@k.Id">
                                            İçerik
                                        </a>

                                        @if (yuzde >= 100)
                                        {
                                            <a class="btn btn-sm btn-outline-success"
                                               asp-area="Egitim" asp-controller="Kurs" asp-action="Sertifikalar">
                                                Sertifika
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="text-muted small mt-3">
                İpucu: Arama kutusundan kurs adı/eğitmen/durum arayabilir, durum filtresiyle hızlı daraltabilirsiniz.
            </div>
        }
    </div>
</div>

@section PageScripts {
    <script>
        (function () {
            const input = document.getElementById("kursAra");
            const filter = document.getElementById("durumFiltre");
            const rows = document.querySelectorAll("#kursTablo tbody tr.kurs-row");

            function apply() {
                const q = (input?.value || "").toLowerCase().trim();
                const f = (filter?.value || "").toLowerCase().trim();

                rows.forEach(r => {
                    const hay = r.getAttribute("data-kurs") || "";
                    const d = r.getAttribute("data-durum") || "";

                    const matchQ = !q || hay.includes(q);
                    const matchF = !f || d.includes(f);

                    r.style.display = (matchQ && matchF) ? "" : "none";
                });
            }

            input?.addEventListener("input", apply);
            filter?.addEventListener("change", apply);
        })();
    </script>
}
