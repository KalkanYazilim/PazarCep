@model PazarCep.Areas.Egitim.Models.EgitimSertifikaSayfaViewModel
@{
    ViewData["Title"] = "Sertifikalarım";
}

<div class="pc-page-shell">
    <section class="pc-page-hero">
        <div class="pc-page-hero__body">
            <span class="pc-page-eyebrow">Eğitim / Sertifikalar</span>
            <h1 class="pc-page-title">@Model.Baslik</h1>
            <p class="pc-page-description mb-0">@Model.Aciklama</p>

            <div class="pc-page-actions mt-4">
                <a asp-area="Egitim" asp-controller="Kurs" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bx bx-arrow-back me-1"></i>Kurs kataloğuna dön
                </a>
            </div>
        </div>
    </section>

    <section class="pc-kpi-grid">
        @foreach (var kart in Model.OzetKartlar)
        {
            <article class="pc-kpi-card h-100">
                <div class="pc-kpi-card__top">
                    <div>
                        <div class="pc-kpi-card__label">@kart.Baslik</div>
                        <div class="pc-kpi-card__value">@kart.Deger</div>
                    </div>
                    <span class="pc-kpi-card__icon"><i class="bx @kart.Ikon"></i></span>
                </div>
                <div class="pc-kpi-card__meta">@kart.Aciklama</div>
            </article>
        }
    </section>

    <section class="pc-panel">
        <div class="pc-panel__header">
            <div>
                <h2 class="pc-panel__title">Belge geçmişi</h2>
                <p class="pc-panel__subtitle mb-0">Tamamlanan eğitimlerin doğrulanmış kapsamı ve referans kodu.</p>
            </div>
        </div>
        <div class="pc-panel__body">
            <div class="pc-mobile-list">
                @foreach (var sertifika in Model.Sertifikalar)
                {
                    <article class="pc-mobile-card">
                        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                            <div>
                                <div class="fw-semibold mb-1">@sertifika.Baslik</div>
                                <p class="text-muted mb-1">@sertifika.Kurum · @sertifika.Tarih</p>
                                <small class="text-muted d-block mb-2">@sertifika.Kapsam</small>
                                <span class="pc-chip"><i class="bx bx-hash"></i>@sertifika.Kod</span>
                            </div>
                            <div class="text-lg-end">
                                <span class="pc-status-pill pc-status-pill--success">Doğrulandı</span>
                            </div>
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>
</div>
