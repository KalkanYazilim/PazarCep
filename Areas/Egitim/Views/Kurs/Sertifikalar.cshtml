@model List<PazarCep.Areas.Egitim.Models.SertifikaSatiriVM>
@{
    ViewData["Title"] = "Sertifikalarım";
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <h5 class="mb-0">Sertifikalarım</h5>
        <a class="btn btn-outline-primary"
           asp-area="Egitim" asp-controller="Kurs" asp-action="Index">
            <i class="bx bx-book-open me-1"></i>Kurslarıma Dön
        </a>
    </div>

    <div class="card-body">
        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-warning mb-0">Henüz sertifika bulunmuyor.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Sertifika</th>
                            <th>Kurum</th>
                            <th class="text-end">Tarih</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.OrderByDescending(x => x.Tarih))
                        {
                            <tr>
                                <td class="fw-semibold">@s.SertifikaAdi</td>
                                <td>@s.Kurum</td>
                                <td class="text-end">@s.Tarih.ToString("dd.MM.yyyy")</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-secondary" disabled>
                                        <i class="bx bx-download me-1"></i>İndir (Yakında)
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
