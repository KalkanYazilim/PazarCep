@model PazarCep.Areas.Egitim.Models.KursIcerikVM
@{
    ViewData["Title"] = "Kurs İçeriği";
}
<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h5 class="mb-1">@Model.KursAdi</h5>
            <div class="text-muted small">Ders Listesi</div>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary"
               asp-area="Egitim" asp-controller="Kurs" asp-action="Detay" asp-route-id="@Model.KursId">
                <i class="bx bx-left-arrow-alt me-1"></i>Detaya Dön
            </a>
            <a class="btn btn-outline-primary"
               asp-area="Egitim" asp-controller="Kurs" asp-action="Index">
                Kurslarım
            </a>
        </div>
    </div>

    <div class="card-body">
        @if (TempData["BasariliMesaj"] != null)
        {
            <div class="alert alert-success">@TempData["BasariliMesaj"]</div>
        }

        @if (Model.Dersler == null || !Model.Dersler.Any())
        {
            <div class="alert alert-warning mb-0">Bu kurs için ders bulunamadı.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Ders</th>
                            <th class="text-end">Süre</th>
                            <th class="text-center">Durum</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.Dersler)
                        {
                            <tr>
                                <td class="fw-semibold">@d.Baslik</td>
                                <td class="text-end">@d.SureDakika dk</td>
                                <td class="text-center">
                                    @if (d.Tamamlandi)
                                    {
                                        <span class="badge bg-label-success">Tamamlandı</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-label-warning">Bekliyor</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @if (!d.Tamamlandi)
                                    {
                                        <form asp-area="Egitim" asp-controller="Kurs" asp-action="DersTamamla"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="kursId" value="@Model.KursId" />
                                            <input type="hidden" name="dersId" value="@d.Id" />
                                            <button type="submit" class="btn btn-sm btn-primary">
                                                <i class="bx bx-check me-1"></i>Tamamla
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" disabled>
                                            Tamam
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
