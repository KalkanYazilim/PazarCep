@model PazarCep.Areas.Egitim.Models.EgitimKursDetaySayfaViewModel
@{
    ViewData["Title"] = "Kurs Detayı";
}

<div class="pc-page-shell">
    <section class="pc-page-hero">
        <div class="pc-page-hero__body">
            <span class="pc-page-eyebrow">Eğitim / Kurs Detayı</span>
            <h1 class="pc-page-title">@Model.KursAdi</h1>
            <p class="pc-page-description mb-0">@Model.Aciklama</p>

            <div class="pc-page-meta mt-4">
                <span><i class="bx bx-user"></i>@Model.Egitmen</span>
                <span><i class="bx bx-layer"></i>@Model.Seviye</span>
                <span><i class="bx bx-time"></i>@Model.Sure</span>
                <span><i class="bx bx-flag"></i>@Model.Durum</span>
            </div>

            <div class="pc-page-actions mt-4">
                <a asp-area="Egitim" asp-controller="Kurs" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bx bx-arrow-back me-1"></i>Kurs listesine dön
                </a>
                <a asp-area="Egitim" asp-controller="Kurs" asp-action="Icerik" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="bx bx-list-ul me-1"></i>İçeriği aç
                </a>
            </div>
        </div>
    </section>

    <section class="pc-kpi-grid">
        @foreach (var kart in Model.OzetKartlar)
        {
            <article class="pc-kpi-card h-100">
                <div class="pc-kpi-card__top">
                    <div>
                        <div class="pc-kpi-card__label">@kart.Baslik</div>
                        <div class="pc-kpi-card__value">@kart.Deger</div>
                    </div>
                    <span class="pc-kpi-card__icon"><i class="bx @kart.Ikon"></i></span>
                </div>
                <div class="pc-kpi-card__meta">@kart.Aciklama</div>
            </article>
        }
    </section>

    <section class="row g-4">
        <div class="col-12 col-xl-7">
            <div class="pc-panel h-100">
                <div class="pc-panel__header">
                    <div>
                        <h2 class="pc-panel__title">Bölüm yapısı</h2>
                        <p class="pc-panel__subtitle mb-0">Kursun modülleri ve tamamlanma durumu.</p>
                    </div>
                </div>
                <div class="pc-panel__body">
                    <div class="pc-mobile-list">
                        @foreach (var bolum in Model.Bolumler)
                        {
                            <article class="pc-mobile-card">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                    <div>
                                        <div class="fw-semibold">@bolum.Baslik</div>
                                        <div class="text-muted">@bolum.Ozet</div>
                                    </div>
                                    <span class="pc-status-pill pc-status-pill--@bolum.Ton">@bolum.Tamamlanma</span>
                                </div>
                                <small class="text-muted">@bolum.DersSayisi</small>
                            </article>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="pc-panel h-100">
                <div class="pc-panel__header">
                    <div>
                        <h2 class="pc-panel__title">Öğrenme kazanımları</h2>
                        <p class="pc-panel__subtitle mb-0">Bu kurs tamamlandığında ekip ne kazanır?</p>
                    </div>
                </div>
                <div class="pc-panel__body">
                    <div class="pc-health-list">
                        @foreach (var kazanim in Model.Kazanimlar)
                        {
                            <article class="pc-health-list__item">
                                <div>
                                    <div class="fw-semibold mb-1">@kazanim</div>
                                </div>
                                <span class="pc-status-pill pc-status-pill--info">Kazanım</span>
                            </article>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
