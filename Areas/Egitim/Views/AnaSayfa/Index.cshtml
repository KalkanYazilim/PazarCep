@model PazarCep.Areas.Egitim.Models.EgitimPanoVM

@if ((TempData["UyariSistemiAktif"] as bool?) == true && TempData["UyariMesaj"] != null)
{
    <div class="alert alert-warning">@TempData["UyariMesaj"]</div>
}

@{
    ViewData["Title"] = "Eğitim - Kontrol Paneli";
}

<div class="row g-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold text-muted">Toplam Kurs</div>
                <h3 class="mb-0">@Model.ToplamKurs</h3>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold text-muted">Devam Edilen</div>
                <h3 class="mb-0">@Model.DevamEdilenKurs</h3>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold text-muted">Tamamlanan</div>
                <h3 class="mb-0">@Model.TamamlananKurs</h3>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card">
            <div class="card-body">
                <div class="fw-semibold text-muted">Sertifika</div>
                <h3 class="mb-0">@Model.SertifikaSayisi</h3>
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card">
            <h5 class="card-header">Son Aktiviteler</h5>
            <div class="card-body">
                @if (Model.SonAktiviteler == null || !Model.SonAktiviteler.Any())
                {
                    <div class="alert alert-warning mb-0">Aktivite bulunamadı.</div>
                }
                else
                {
                    <ul class="list-group">
                        @foreach (var a in Model.SonAktiviteler.OrderByDescending(x => x.Tarih))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-semibold">@a.Baslik</div>
                                    <div class="text-muted">@a.Aciklama</div>
                                </div>
                                <small class="text-muted">@a.Tarih.ToString("dd.MM.yyyy")</small>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
