                        <li><a class="dropdown-item" href="javascript:void(0);">Başka bir seçenek</a></li>
                        <li>
                            <hr class="dropdown-divider" />
                        </li>
                        <li><a class="dropdown-item" href="javascript:void(0);">Ayrı bağlantı</a></li>
                    </ul>
                    <input type="text" class="form-control" aria-label="Açılır menülü buton ile metin girişi" />
                </div>

                <div class="input-group">
                    <input type="text" class="form-control" aria-label="Açılır menülü buton ile metin girişi" />
                    <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">Açılır menü</button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="javascript:void(0);">İşlem</a></li>
                        <li><a class="dropdown-item" href="javascript:void(0);">Başka bir işlem</a></li>
                        <li><a class="dropdown-item" href="javascript:void(0);">Başka bir seçenek</a></li>
                        <li>
                            <hr class="dropdown-divider" />
                        </li>
                        <li><a class="dropdown-item" href="javascript:void(0);">Ayrı bağlantı</a></li>
                    </ul>
                </div>

                <div class="input-group">
                    <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">Açılır menü</button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="javascript:void(0);">Öncesi için işlem</a></li>
                        <li><a class="dropdown-item" href="javascript:void(0);">Öncesi için başka işlem</a></li>
                        <li><a class="dropdown-item" href="javascript:void(0);">Başka bir seçenek</a></li>
                        <li>
                            <hr class="dropdown-divider" />
                        </li>
                        <li><a class="dropdown-item" href="javascript:void(0);">Ayrı bağlantı</a></li>
                    </ul>
                    <input type="text" class="form-control" aria-label="İki açılır menülü buton ile metin girişi" />
                    <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">Açılır menü</button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="javascript:void(0);">İşlem</a></li>
                        <li><a class="dropdown-item" href="javascript:void(0);">Başka bir işlem</a></li>
                        <li><a class="dropdown-item" href="javascript:void(0);">Başka bir seçenek</a></li>
                        <li>
                            <hr class="dropdown-divider" />
                        </li>
                        <li><a class="dropdown-item" href="javascript:void(0);">Ayrı bağlantı</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <!-- Segmented buttons -->
        <div class="row g-6 mb-6">
            <div class="col-12">
                <div class="card">
                    <h5 class="card-header">Bölünmüş butonlar</h5>
                    <div class="card-body demo-vertical-spacing demo-only-element">
                        <div class="input-group">
                            <button type="button" class="btn btn-outline-primary">İşlem</button>
                            <button type="button" class="btn btn-outline-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="visually-hidden">Açılır menüyü aç/kapat</span>
                            </button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="javascript:void(0);">İşlem</a></li>
                                <li><a class="dropdown-item" href="javascript:void(0);">Başka bir işlem</a></li>
                                <li><a class="dropdown-item" href="javascript:void(0);">Başka bir seçenek</a></li>
                                <li>
                                    <hr class="dropdown-divider" />
                                </li>
                                <li><a class="dropdown-item" href="javascript:void(0);">Ayrı bağlantı</a></li>
                            </ul>
                            <input type="text" class="form-control" aria-label="Bölünmüş açılır menülü buton ile metin girişi" />
                        </div>

                        <div class="input-group">
                            <input type="text" class="form-control" aria-label="Bölünmüş açılır menülü buton ile metin girişi" />
                            <button type="button" class="btn btn-outline-primary">İşlem</button>
                            <button type="button" class="btn btn-outline-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false">
                                <span class="visually-hidden">Açılır menüyü aç/kapat</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="javascript:void(0);">İşlem</a></li>
                                <li><a class="dropdown-item" href="javascript:void(0);">Başka bir işlem</a></li>
                                <li><a class="dropdown-item" href="javascript:void(0);">Başka bir seçenek</a></li>
                                <li>
                                    <hr class="dropdown-divider" />
                                </li>
                                <li><a class="dropdown-item" href="javascript:void(0);">Ayrı bağlantı</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Custom select -->
        <div class="row g-6 mb-6">
            <div class="col-12">
                <div class="card">
                    <h5 class="card-header">Özel seçim kutusu</h5>
                    <div class="card-body demo-vertical-spacing demo-only-element">
                        <div class="input-group">
                            <label class="input-group-text" for="inputGroupSelect01">Seçenekler</label>
                            <select class="form-select" id="inputGroupSelect01">
                                <option selected>Seçiniz...</option>
                                <option value="1">Bir</option>
                                <option value="2">İki</option>
                                <option value="3">Üç</option>
                            </select>
                        </div>

                        <div class="input-group">
                            <select class="form-select" id="inputGroupSelect02">
                                <option selected>Seçiniz...</option>
                                <option value="1">Bir</option>
                                <option value="2">İki</option>
                                <option value="3">Üç</option>
                            </select>
                            <label class="input-group-text" for="inputGroupSelect02">Seçenekler</label>
                        </div>

                        <div class="input-group">
                            <button class="btn btn-outline-primary" type="button">Buton</button>
                            <select class="form-select" id="inputGroupSelect03" aria-label="Buton ekli seçim kutusu örneği">
                                <option selected>Seçiniz...</option>
                                <option value="1">Bir</option>
                                <option value="2">İki</option>
                                <option value="3">Üç</option>
                            </select>
                        </div>

                        <div class="input-group">
                            <select class="form-select" id="inputGroupSelect04" aria-label="Buton ekli seçim kutusu örneği">
                                <option selected>Seçiniz...</option>
                                <option value="1">Bir</option>
                                <option value="2">İki</option>
                                <option value="3">Üç</option>
                            </select>
                            <button class="btn btn-outline-primary" type="button">Buton</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Custom file input -->
<div class="row">
    <div class="col-12">
        <div class="card">
            <h5 class="card-header">Özel dosya girişi</h5>
            <div class="card-body demo-vertical-spacing demo-only-element">
                <div class="input-group">
                    <label class="input-group-text" for="inputGroupFile01">Yükle</label>
                    <input type="file" class="form-control" id="inputGroupFile01" />
                </div>

                <div class="input-group">
                    <input type="file" class="form-control" id="inputGroupFile02" />
                    <label class="input-group-text" for="inputGroupFile02">Yükle</label>
                </div>

                <div class="input-group">
                    <button class="btn btn-outline-primary" type="button" id="inputGroupFileAddon03">Buton</button>
                    <input type="file" class="form-control" id="inputGroupFile03" aria-describedby="inputGroupFileAddon03" aria-label="Yükle" />
                </div>

                <div class="input-group">
                    <input type="file" class="form-control" id="inputGroupFile04" aria-describedby="inputGroupFileAddon04" aria-label="Yükle" />
                    <button class="btn btn-outline-primary" type="button" id="inputGroupFileAddon04">Buton</button>
                </div>
            </div>
        </div>
    </div>
</div>
