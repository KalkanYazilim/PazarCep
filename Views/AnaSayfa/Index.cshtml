@{
    ViewData["Title"] = "Ana Sayfa";
    //Layout = "_CommonMasterLayout
}
@section PageScripts {
    <script src="~/js/Custom_Home.js" asp-append-version="true"></script>
}

<!-- HEADER -->
<div class="pc-header-wrap">
    <header class="pc-header pc-container">
        <a href="#hero" class="pc-logo">
            <!-- <div class="pc-logo-mark"><span>PC</span></div> -->
            <div class="pc-logo-mark">
                <img src="~/img/favicon/PazarCep_Logo.ico" alt="PazarCep Logo" class="pc-logo-icon" />
            </div>
            <!-- Logoyu bu satırdan değiştiriyoruz -->
            <div class="pc-logo-text">
                <div class="pc-logo-text-main">PazarCep</div>
                <div class="pc-logo-text-sub">Çiftçiden Pazara Dijital Pazar</div>
            </div>
        </a>

        <nav class="pc-nav">
            <div class="pc-nav-links">
                <a href="#roles">Kimin için?</a>
                <a href="#how">Nasıl çalışır?</a>
                <a href="#modules">Modüller</a>
                <a href="#pricing">Canlı fiyatlar</a>
                <a href="#faq">SSS</a>
            </div>
            <div class="pc-nav-cta">
                <button class="pc-btn pc-btn-ghost" onclick="scrollToSection('demo')">Demo Talep Et</button>
                <button class="pc-btn pc-btn-primary" onclick="scrollToSection('contact')">
                    Hemen Başla
                </button>
            </div>
            <button class="pc-mobile-toggle" id="pcMobileToggle" aria-label="Menüyü aç/kapat">
                <span></span>
            </button>
        </nav>
    </header>
    <div class="pc-container pc-nav-mobile" id="pcMobileNav">
        <div class="pc-nav-mobile-links">
            <a href="#roles">Kimin için?</a>
            <a href="#how">Nasıl çalışır?</a>
            <a href="#modules">Modüller</a>
            <a href="#pricing">Canlı fiyatlar</a>
            <a href="#faq">SSS</a>
        </div>
        <div class="pc-nav-mobile-cta">
            <button class="pc-btn pc-btn-ghost" onclick="scrollToSection('demo')">Demo</button>
            <button class="pc-btn pc-btn-primary" onclick="scrollToSection('contact')">Kayıt ol</button>
        </div>
    </div>
</div>

<!-- HERO -->
<main id="hero" class="pc-section pc-hero">
    <div class="pc-container pc-hero-grid">
        <div>
            <div class="pc-kicker">
                <span class="pc-kicker-dot"></span>
                Türkiye tarımı için uçtan uca dijital altyapı
            </div>
            <h1 class="pc-hero-title">
                <span>Çiftçiden Pazara</span> tüm zincir<br />tek platformda.
            </h1>
            <p class="pc-hero-sub">
                PazarCep; <strong>çiftçi</strong>, <strong>alıcı</strong>, <strong>lojistik</strong> ve
                <strong>hal/depo</strong> süreçlerini tek ekrandan yöneten,
                <strong>PazarPara</strong> destekli akıllı bir pazaryeri altyapısıdır.
            </p>

            <div class="pc-hero-cta-row">
                <button class="pc-btn pc-btn-primary" onclick="scrollToSection('contact')">
                    Erken erişime kayıt ol
                </button>
                <button class="pc-btn pc-btn-ghost" onclick="scrollToSection('how')">
                    Sistemi incele
                </button>
                <span class="pc-hero-note">
                    <span class="pc-pill">7 gün ücretsiz deneme</span>
                </span>
            </div>

            <div class="pc-hero-note">
                <span>• Hal kayıt, e-fatura ve sevkiyat yönetimi tek panelde.</span>
            </div>

            <div class="pc-hero-stats">
                <div class="pc-stat">
                    <div class="pc-stat-label">Pilot bölge çiftçi sayısı</div>
                    <div class="pc-stat-value">500+ <span>kayıtlı üretici</span></div>
                </div>
                <div class="pc-stat">
                    <div class="pc-stat-label">Teslimat süresi</div>
                    <div class="pc-stat-value">&minus;%35 <span>gecikme</span></div>
                </div>
                <div class="pc-stat">
                    <div class="pc-stat-label">Fire oranı</div>
                    <div class="pc-stat-value">&minus;%22 <span>ortalama</span></div>
                </div>
            </div>
        </div>

        <div class="pc-hero-visual">
            <!-- Basit akış diyagramı -->
            <div class="pc-hero-card">
                <div class="pc-map-header">
                    <div class="pc-map-title">
                        Tedarik Zinciri Akışı
                        <span class="pc-map-badge">PazarCep canlı</span>
                    </div>
                    <div class="pc-map-pill-row">
                        <span class="pc-map-pill">Canlı stok</span>
                        <span class="pc-map-pill">Dinamik fiyat</span>
                    </div>
                </div>

                <div class="pc-map-grid">
                    <div class="pc-map-node">
                        <div class="pc-map-node-label">Çiftçi</div>
                        <div class="pc-map-node-role">Bahçesinden sisteme girer</div>
                        <div class="pc-map-node-tag">Ürün / miktar / kalite</div>
                    </div>
                    <div class="pc-map-node">
                        <div class="pc-map-node-label">Hal & Depo</div>
                        <div class="pc-map-node-role">Toplama & sınıflandırma</div>
                        <div class="pc-map-node-tag">Lot & etiket & HKS</div>
                    </div>
                    <div class="pc-map-node">
                        <div class="pc-map-node-label">Alıcı</div>
                        <div class="pc-map-node-role">Market / restoran / toptancı</div>
                        <div class="pc-map-node-tag">Tek tıkla sipariş</div>
                    </div>
                </div>

                <div class="pc-map-timeline">
                    <div class="pc-map-step">
                        <div class="pc-map-step-title">01 • İlan açılır</div>
                        <div class="pc-map-step-sub">Çiftçi ürününü kg, kalibre, sertifika ile ekler.</div>
                    </div>
                    <div class="pc-map-step">
                        <div class="pc-map-step-title">02 • Eşleşme</div>
                        <div class="pc-map-step-sub">
                            PazarCep, alıcı tekliflerini ve rota maliyetlerini otomatik eşleştirir.
                        </div>
                    </div>
                    <div class="pc-map-step">
                        <div class="pc-map-step-title">03 • Lojistik</div>
                        <div class="pc-map-step-sub">
                            Araç, yükleme noktalarını uygulamadan alır, anlık takip edilir.
                        </div>
                    </div>
                    <div class="pc-map-step">
                        <div class="pc-map-step-title">04 • Ödeme</div>
                        <div class="pc-map-step-sub">
                            Tahsilat PazarCep güvencesi ile, PazarPara ve TL olarak bölüştürülür.
                        </div>
                    </div>
                </div>
            </div>

            <div class="pc-hero-mini-card">
                <strong>Gerçek zamanlı panel</strong><br />
                <span>Canlı siparişler, bekleyen yüklemeler ve rota maliyetleri tek ekranda.</span>
            </div>
        </div>
    </div>
</main>

<!-- ROLES -->
<section id="roles" class="pc-section">
    <div class="pc-container">
        <div class="pc-section-header">
            <div class="pc-section-eyebrow">Kimin İçin?</div>
            <h2 class="pc-section-title">Tüm paydaşlar için tek PazarCep.</h2>
            <p class="pc-section-sub">
                Çiftçi, alıcı, lojistik firması ve depo işletmecisi aynı ekosistem içinde, kendi ekranına
                sahip olur.
            </p>
        </div>

        <div class="pc-role-grid">
            <article class="pc-card">
                <div class="pc-card-header">
                    <h3 class="pc-card-title">Çiftçi Paneli</h3>
                    <span class="pc-chip">Tarladan sisteme</span>
                </div>
                <p class="pc-card-desc">
                    Akıllı telefon veya web üzerinden ürün girişleri, teklifleri ve ödemeleri takip edin.
                </p>
                <ul class="pc-card-list">
                    <li>Toplu ürün ekleme (domates, biber, patates, vb.)</li>
                    <li>Minimum satış miktarı ve hedef fiyat tanımlama</li>
                    <li>Ürün geçmişi, önceki satış ortalamaları</li>
                    <li>PazarPara bakiyesi, nakit & vadeli ödemeler</li>
                </ul>
            </article>

            <article class="pc-card">
                <div class="pc-card-header">
                    <h3 class="pc-card-title">Alıcı Paneli</h3>
                    <span class="pc-chip">Market / restoran / toptancı</span>
                </div>
                <p class="pc-card-desc">
                    Bölgesel veya ürün bazlı filtreler ile güvenilir üreticilere direkt erişim sağlayın.
                </p>
                <ul class="pc-card-list">
                    <li>Şehir, ürün, sertifika ve kalite filtreleme</li>
                    <li>Tek tıkla tekrarlayan sipariş oluşturma</li>
                    <li>Dinamik navlun (lojistik) fiyat önerisi</li>
                    <li>E-fatura, irsaliye ve sözleşmeler tek panelde</li>
                </ul>
            </article>

            <article class="pc-card">
                <div class="pc-card-header">
                    <h3 class="pc-card-title">Lojistik & Depo</h3>
                    <span class="pc-chip">Ara nokta yönetimi</span>
                </div>
                <p class="pc-card-desc">
                    Araç doluluk oranı, rota planlama ve hal/depo stokları anlık yönetilir.
                </p>
                <ul class="pc-card-list">
                    <li>Araç bazlı rota planlama ve GPS entegrasyonu</li>
                    <li>Hal & depo giriş/çıkış, lot bazlı stok takip</li>
                    <li>Yükleme randevu slot yönetimi</li>
                    <li>Anlık teslimat durumu ve gecikme uyarıları</li>
                </ul>
            </article>
        </div>
    </div>
</section>

<!-- HOW IT WORKS -->
<section id="how" class="pc-section" style="background: rgba(248, 250, 252, 0.9);">
    <div class="pc-container">
        <div class="pc-section-header">
            <div class="pc-section-eyebrow">Nasıl Çalışır?</div>
            <h2 class="pc-section-title">4 adımda PazarCep akışı.</h2>
            <p class="pc-section-sub">
                Her rol kendi ekranını kullanır ama tüm süreçler tek zincirde birleşir. Aşağıdaki adımlar
                örnek bir çiftçi&ndash;alıcı senaryosudur.
            </p>
        </div>

        <div class="pc-steps-grid">
            <div class="pc-step-card">
                <div class="pc-step-tag">Adım 1 &mdash; Çiftçi</div>
                <div class="pc-step-number">Ürün ilanı</div>
                <div class="pc-step-title">Ürün ve kalite girişleri</div>
                <p>
                    Çiftçi; ürün türü, kalibre, beklenen hasat tarihi, miktar ve sertifika bilgilerini girer.
                    Fotoğraf ve belge ekleyebilir.
                </p>
            </div>
            <div class="pc-step-card">
                <div class="pc-step-tag">Adım 2 &mdash; Alıcı</div>
                <div class="pc-step-number">Talep oluşturma</div>
                <div class="pc-step-title">Teklif & rezervasyon</div>
                <p>
                    Alıcı; talep ettiği ürün, miktar, teslim yeri ve tarih aralığını seçer, sistem en uygun
                    üretici ve lojistikle eşleştirir.
                </p>
            </div>
            <div class="pc-step-card">
                <div class="pc-step-tag">Adım 3 &mdash; Lojistik</div>
                <div class="pc-step-number">Yükleme & taşıma</div>
                <div class="pc-step-title">Rota planlama</div>
                <p>
                    Lojistik firması; PazarCep üzerinden rota, araç ve şoför atamasını yapar, alıcı ve çiftçi
                    anlık takip eder.
                </p>
            </div>
            <div class="pc-step-card">
                <div class="pc-step-tag">Adım 4 &mdash; Ödeme</div>
                <div class="pc-step-number">Tahsilat</div>
                <div class="pc-step-title">PazarPara & TL dağıtımı</div>
                <p>
                    Ödeme, PazarCep havuzunda güvence altına alınır; çiftçi, lojistik ve komisyon oranları
                    otomatik bölüştürülür.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- MODULES -->
<section id="modules" class="pc-section">
    <div class="pc-container">
        <div class="pc-section-header">
            <div class="pc-section-eyebrow">Modüller</div>
            <h2 class="pc-section-title">PazarCep çekirdek modülleri.</h2>
            <p class="pc-section-sub">
                İleride büyütebileceğiniz çekirdek yapıyı, mikro servis mantığıyla planlayın. Aşağıdaki
                modüller örnek mimariyi özetler.
            </p>
        </div>

        <div class="pc-modules-grid">
            <article class="pc-card">
                <div class="pc-module-top">
                    <span class="pc-tag-pill pc-chip-success">Pazar yeri</span>
                    <span class="pc-tag-pill">Ürün & ilan</span>
                </div>
                <h3 class="pc-card-title">Ürün & İlan Yönetimi</h3>
                <p class="pc-card-desc">
                    Üretici ve alıcı tarafında görünen tüm ürün listeleme, filtreleme ve arama modülleri.
                </p>
                <ul class="pc-card-list">
                    <li>Çok dilli ürün adı / açıklama</li>
                    <li>Bölgeye göre isimlendirme (domates / domat)</li>
                    <li>Kalite sınıfları ve sertifikalar</li>
                </ul>
                <div class="pc-module-footer">
                    <span>API: <strong>/products</strong></span>
                    <div class="pc-dot-row">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </article>

            <article class="pc-card">
                <div class="pc-module-top">
                    <span class="pc-tag-pill pc-chip-success">Finans</span>
                    <span class="pc-tag-pill">Ödeme</span>
                </div>
                <h3 class="pc-card-title">PazarPara & Ödeme</h3>
                <p class="pc-card-desc">
                    Cüzdan, komisyon, vadeli ödeme ve PazarPara mantığını yöneten finans katmanı.
                </p>
                <ul class="pc-card-list">
                    <li>Cüzdan bakiyesi ve hareketler</li>
                    <li>Paylaşmalı ödeme (çiftçi + lojistik + komisyon)</li>
                    <li>Erken ödeme & iskonto senaryoları</li>
                </ul>
                <div class="pc-module-footer">
                    <span>API: <strong>/wallet</strong></span>
                    <div class="pc-dot-row">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </article>

            <article class="pc-card">
                <div class="pc-module-top">
                    <span class="pc-tag-pill pc-chip-success">Lojistik</span>
                    <span class="pc-tag-pill">Rota & sevkiyat</span>
                </div>
                <h3 class="pc-card-title">Lojistik Yönetimi</h3>
                <p class="pc-card-desc">
                    Araç atama, rota planlama, yükleme noktasına göre puanlı navlun sistemi.
                </p>
                <ul class="pc-card-list">
                    <li>Canlı harita ve tahmini varış saatleri</li>
                    <li>Araç doluluk oranı ve konsolidasyon</li>
                    <li>Şoför mobil uygulaması ile entegrasyon</li>
                </ul>
                <div class="pc-module-footer">
                    <span>API: <strong>/logistics</strong></span>
                    <div class="pc-dot-row">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </article>

            <article class="pc-card">
                <div class="pc-module-top">
                    <span class="pc-tag-pill pc-chip-success">Hal & Depo</span>
                    <span class="pc-tag-pill">Stok</span>
                </div>
                <h3 class="pc-card-title">Hal & Depo Stok</h3>
                <p class="pc-card-desc">
                    Lot bazlı stok, ürün giriş&ndash;çıkış hareketleri ve raf ömürleri.
                </p>
                <ul class="pc-card-list">
                    <li>Hal kayıt sistemi uyumlu yapı</li>
                    <li>Lot / palet / sandık bazlı takip</li>
                    <li>Fire, iade ve kalite düşüş raporları</li>
                </ul>
                <div class="pc-module-footer">
                    <span>API: <strong>/warehouse</strong></span>
                    <div class="pc-dot-row">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </article>

            <article class="pc-card">
                <div class="pc-module-top">
                    <span class="pc-tag-pill pc-chip-success">Raporlama</span>
                    <span class="pc-tag-pill">Analitik</span>
                </div>
                <h3 class="pc-card-title">Raporlama & Analitik</h3>
                <p class="pc-card-desc">
                    Tüm modüllerden beslenen karar destek panelleri, KPI ve grafik setleri.
                </p>
                <ul class="pc-card-list">
                    <li>Çiftçi bazlı gelir & ürün performansları</li>
                    <li>Bölge, ürün ve sezon bazlı istatistikler</li>
                    <li>Excel / PDF dışa aktarma</li>
                </ul>
                <div class="pc-module-footer">
                    <span>API: <strong>/reports</strong></span>
                    <div class="pc-dot-row">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </article>

            <article class="pc-card">
                <div class="pc-module-top">
                    <span class="pc-tag-pill pc-chip-success">Eğitim</span>
                    <span class="pc-tag-pill">Danışmanlık</span>
                </div>
                <h3 class="pc-card-title">Eğitim & Danışmanlık</h3>
                <p class="pc-card-desc">
                    Ziraat mühendisi destek hatları, eğitim videoları ve canlı yayınlar için içerik hub.
                </p>
                <ul class="pc-card-list">
                    <li>Bölgeye göre önerilen eğitim içerikleri</li>
                    <li>Canlı yayın takvimi ve kayıt sistemi</li>
                    <li>Çiftçiden soru & uzman cevap modu</li>
                </ul>
                <div class="pc-module-footer">
                    <span>API: <strong>/academy</strong></span>
                    <div class="pc-dot-row">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>

<!-- METRICS & SAMPLE PRICING -->
<section id="pricing" class="pc-section" style="background: rgba(248, 250, 252, 0.9);">
    <div class="pc-container">
        <div class="pc-section-header">
            <div class="pc-section-eyebrow">Canlı Fiyat & İstatistik Örneği</div>
            <h2 class="pc-section-title">PazarCep panelinde göreceğiniz tarzda ekranlar.</h2>
            <p class="pc-section-sub">
                Aşağıdaki tablo ve kartlar demo amaçlıdır; gerçek sistemde bölge, ürün, tarih ve lojistik
                maliyetlerine göre dinamik çalışır.
            </p>
        </div>

        <div class="pc-metrics-layout">
            <div class="pc-table-wrap">
