<!-- CONTACT / EARLY ACCESS -->
<section id="contact" class="pc-section">
    <div class="pc-container">
        <div class="pc-contact-card">
            <div>
                <h2 class="pc-contact-left-title">PazarCep lansmanına erkenden dahil olun.</h2>
                <p class="pc-contact-left-sub">
                    Aşağıdaki form, sadece ön başvuru formudur. Canlıya alım aşamasında sizinle iletişime
                    geçebilmemiz için temel bilgileri bırakmanız yeterlidir.
                </p>
                <div class="pc-contact-badges">
                    <span class="pc-contact-badge">Çiftçi / üretici</span>
                    <span class="pc-contact-badge">Market / restoran / toptancı</span>
                    <span class="pc-contact-badge">Lojistik / nakliye</span>
                    <span class="pc-contact-badge">Hal / depo işletmecisi</span>
                </div>
            </div>

            <form class="pc-contact-form" id="pcContactForm">
                <div class="pc-form-field">
                    <label for="pcName">Ad Soyad</label>
                    <input type="text" id="pcName" name="name" placeholder="Adınız Soyadınız" required />
                </div>

                <div class="pc-form-field">
                    <label for="pcRole">Rolünüz</label>
                    <select id="pcRole" name="role" required>
                        <option value="">Seçiniz</option>
                        <option value="ciftci">Çiftçi / Üretici</option>
                        <option value="alici">Alıcı (Market, restoran, otel vb.)</option>
                        <option value="lojistik">Lojistik / Nakliye</option>
                        <option value="depo">Hal / Depo İşletmesi</option>
                        <option value="diger">Diğer</option>
                    </select>
                </div>

                <div class="pc-form-field">
                    <label for="pcPhone">Telefon</label>
                    <input type="tel" id="pcPhone" name="phone" placeholder="05xx xxx xx xx" required />
                </div>

                <div class="pc-form-field">
                    <label for="pcCity">İl</label>
                    <input type="text" id="pcCity" name="city" placeholder="Örn. Niğde" required />
                </div>

                <div class="pc-form-field pc-form-field-full">
                    <label for="pcMessage">Kısaca ihtiyacınızı anlatın</label>
                    <textarea id="pcMessage" name="message" placeholder="Mevcut süreciniz, PazarCep'ten beklentiniz..." required></textarea>
                </div>

                <div class="pc-form-foot">
                    <div>
                        <button type="submit" class="pc-btn pc-btn-primary">
                            Başvurumu gönder
                        </button>
                        <span id="pcFormSuccess" class="pc-form-success">
                            Başvurunuz alındı (demo amaçlı mesaj).
                        </span>
                    </div>
                    <div class="pc-form-note">
                        Verileriniz yalnızca PazarCep lansman bilgilendirmesi için kullanılacaktır.
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>

