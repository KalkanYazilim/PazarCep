                            <td>1,80 ₺</td>
                            <td><span class="pc-chip-inline">PazarPara + TL</span></td>
                        </tr>
                        <tr>
                            <td>Salatalık</td>
                            <td>12,20 ₺</td>
                            <td>16,30 ₺</td>
                            <td>1,10 ₺</td>
