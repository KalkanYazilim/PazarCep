@model RoleDashboardViewModel
@{
    ViewData["Title"] = Model.Title;
}

@section PageStyles {
    <link rel="stylesheet" href="~/css/business-panels.css" asp-append-version="true" />
}

<div class="pc-page-shell pc-business-panel">
    <section class="pc-page-hero pc-business-hero pc-business-hero--@Model.RoleKey.ToLowerInvariant()">
        <div class="pc-page-hero__body">
            <span class="pc-page-eyebrow">Rol Bazlı Yönetim</span>
            <h1 class="pc-page-title">@Model.Title</h1>
            <p class="pc-page-description mb-0">@Model.Subtitle</p>
            @await Html.PartialAsync("_RoleSwitcher", Model.RoleSwitcher)
            <div class="pc-page-actions mt-4">
                @foreach (var action in Model.QuickActions)
                {
                    <a asp-controller="Panel" asp-action="@action.TargetAction" class="btn btn-outline-secondary">
                        <i class="bx @action.Icon me-1"></i>@action.Text
                    </a>
                }
            </div>
        </div>
    </section>

    <section class="pc-kpi-grid pc-business-kpi-grid">
        @foreach (var metric in Model.Metrics)
        {
            <article class="pc-kpi-card h-100">
                <div class="pc-kpi-card__top">
                    <div>
                        <div class="pc-kpi-card__label">@metric.Title</div>
                        <div class="pc-kpi-card__value">@metric.Value</div>
                    </div>
                    <span class="pc-kpi-card__icon"><i class="bx @metric.Icon"></i></span>
                </div>
                <div class="pc-kpi-card__meta">@metric.Description</div>
            </article>
        }
    </section>

    <section class="pc-business-dashboard-grid">
        <div class="pc-business-main-stack">
            @foreach (var table in Model.Tables)
            {
                @await Html.PartialAsync("_PanelTable", table)
            }
        </div>
        <aside class="pc-panel">
            <div class="pc-panel__header">
                <div>
                    <h2 class="pc-panel__title">Günlük Operasyon Akışı</h2>
                    <p class="pc-panel__subtitle mb-0">Rolünüzle ilgili öncelikli kayıtlar.</p>
                </div>
            </div>
            <div class="pc-panel__body">
                <div class="pc-business-timeline">
                    @foreach (var item in Model.Timeline)
                    {
                        <article class="pc-business-timeline__item pc-business-timeline__item--@item.Tone">
                            <span>@item.Time</span>
                            <strong>@item.Title</strong>
                            <p>@item.Description</p>
                        </article>
                    }
                </div>
            </div>
        </aside>
    </section>
</div>
