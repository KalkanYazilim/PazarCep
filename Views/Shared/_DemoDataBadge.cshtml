@* Demo/Örnek veri kullanan sayfalarda görünür işaret *@
@if (ViewData["DemoVeri"] is true)
{
    <div class="alert alert-warning d-flex align-items-center py-2 px-3 mb-3" role="alert"
         style="border-left: 6px solid #f0ad4e;">
        <i class="bx bx-flask me-2"></i>
        <div class="flex-grow-1">
            <strong>ÖRNEK VERİ</strong>
            <span class="ms-2 text-muted">Bu sayfa şu an demo veriyle çalışıyor.</span>
        </div>
        @if (!string.IsNullOrWhiteSpace(ViewData["DemoVeriNotu"]?.ToString()))
        {
            <span class="badge bg-label-warning text-dark ms-2">@ViewData["DemoVeriNotu"]</span>
        }
    </div>
}
