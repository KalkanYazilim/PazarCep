@{
    TempData.Keep();
    var currentPage = ViewContext.HttpContext.Request.Path.Value ?? "/";

    bool StartsWithPath(string prefix) => currentPage.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
    bool MatchesPath(string path) => string.Equals(currentPage, path, StringComparison.OrdinalIgnoreCase);
}

