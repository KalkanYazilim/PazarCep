                                        ? " active" : "")'>
                            <a asp-area="Egitim" asp-controller="Kurs" asp-action="Index" class="menu-link">
                                <div class="text-truncate">KurslarГғЖ’ГўвӮ¬ВһГғвҖҡГӮВұm</div>
