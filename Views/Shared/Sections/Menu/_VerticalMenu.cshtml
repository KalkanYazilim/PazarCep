        <li class='menu-item@((currentPage ?? "").StartsWith("/", StringComparison.OrdinalIgnoreCase) ? " active open" : "")'>
            <a href="javascript:void(0);" class="menu-link menu-toggle">
                <i class="menu-icon icon-base bx bx-home-smile"></i>
                <div class="text-truncate" data-i18n="Dashboards">Paneller</div>
