@model PazarCep.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Kontrol Merkezi";
}

<div class="pc-page-shell">
    <section class="pc-page-hero">
        <div class="pc-page-hero__body">
            <span class="pc-page-eyebrow">Admin Paneli / Canlı Operasyon</span>
            <h1 class="pc-page-title">@Model.Baslik</h1>
            <p class="pc-page-description mb-0">@Model.Aciklama</p>

            <div class="pc-page-meta mt-4">
                <span><i class="bx bx-calendar"></i>22 Nisan 2026 operasyon görünümü</span>
                <span><i class="bx bx-layout"></i>Paylaşılan responsive kabuk aktif</span>
                <span><i class="bx bx-check-shield"></i>Preview değerlendirmesine hazır</span>
            </div>

            <div class="pc-page-actions mt-4">
                <a asp-area="ETicaret" asp-controller="AnaSayfa" asp-action="Index" class="btn btn-primary">
                    <i class="bx bx-store-alt me-1"></i>E-Ticaret operasyonu
                </a>
                <a asp-area="Lojistik" asp-controller="AnaSayfa" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bx bx-car me-1"></i>Lojistik görünümü
                </a>
                <a asp-area="MusteriYonetimi" asp-controller="AnaSayfa" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bx bx-briefcase-alt-2 me-1"></i>CRM çalışma alanı
                </a>
            </div>
        </div>
    </section>

    <section class="pc-kpi-grid">
        @foreach (var kart in Model.OzetKartlar)
        {
            <article class="pc-kpi-card h-100">
                <div class="pc-kpi-card__top">
                    <div>
                        <div class="pc-kpi-card__label">@kart.Baslik</div>
                        <div class="pc-kpi-card__value">@kart.Deger</div>
                    </div>
                    <span class="pc-kpi-card__icon"><i class="bx @kart.Ikon"></i></span>
                </div>
                <div class="pc-kpi-card__meta">@kart.Aciklama</div>
                <div class="pc-kpi-card__trend">
                    <i class="bx bx-trending-up"></i>@kart.Trend
                </div>
            </article>
        }
    </section>

    <section class="row g-4">
        <div class="col-12 col-xl-7">
            <div class="pc-panel h-100">
                <div class="pc-panel__header">
                    <div>
                        <h2 class="pc-panel__title">Öncelikli iş listesi</h2>
                        <p class="pc-panel__subtitle mb-0">Panel yöneticisinin bugün kapatması gereken kritik işler.</p>
                    </div>
                    <span class="pc-chip">4 aktif başlık</span>
                </div>
                <div class="pc-panel__body">
                    <div class="pc-mobile-list">
                        @foreach (var isKalemi in Model.IsListesi)
                        {
                            <article class="pc-mobile-card">
                                <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                                    <div>
                                        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                            <strong>@isKalemi.Baslik</strong>
                                            <span class="pc-status-pill pc-status-pill--@isKalemi.DurumTonu">@isKalemi.Durum</span>
                                        </div>
                                        <p class="text-muted mb-2">@isKalemi.Aciklama</p>
                                        <div class="pc-chip-row">
                                            <span class="pc-chip"><i class="bx bx-group"></i>@isKalemi.Takim</span>
                                            <span class="pc-chip"><i class="bx bx-time-five"></i>Son tarih: @isKalemi.SonTarih</span>
                                        </div>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="pc-panel h-100">
                <div class="pc-panel__header">
                    <div>
                        <h2 class="pc-panel__title">Risk ve uyarılar</h2>
                        <p class="pc-panel__subtitle mb-0">Canlı operasyonda dikkat gerektiren alanlar.</p>
                    </div>
                </div>
                <div class="pc-panel__body">
                    <div class="pc-health-list">
                        @foreach (var uyari in Model.Uyarilar)
                        {
                            <article class="pc-alert-strip pc-alert-strip--@uyari.Ton">
                                <div>
                                    <div class="fw-semibold mb-1">@uyari.Baslik</div>
                                    <p class="text-muted mb-0">@uyari.Ozet</p>
                                </div>
                                <a href="@uyari.EylemLinki" class="btn btn-outline-secondary btn-sm">@uyari.EylemMetni</a>
                            </article>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="row g-4">
        <div class="col-12 col-xl-7">
            <div class="pc-panel h-100">
                <div class="pc-panel__header">
                    <div>
                        <h2 class="pc-panel__title">Modül sağlığı</h2>
                        <p class="pc-panel__subtitle mb-0">Tamamlanma, kalite ve operasyonel güven görünümü.</p>
                    </div>
                </div>
                <div class="pc-panel__body">
                    <div class="pc-module-grid">
                        @foreach (var modul in Model.Moduller)
                        {
                            <article class="pc-module-card">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                    <div>
                                        <h3 class="h6 mb-1">@modul.Baslik</h3>
                                        <p class="text-muted mb-0">@modul.Ozet</p>
                                    </div>
                                    <span class="pc-status-pill pc-status-pill--@modul.SaglikTonu">@modul.SaglikDurumu</span>
                                </div>
                                <div class="pc-progress-meter mb-2">
                                    <span style="width:@modul.TamamlanmaYuzdesi%"></span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">Tamamlanma seviyesi</small>
                                    <strong>%@modul.TamamlanmaYuzdesi</strong>
                                </div>
                                <div class="mt-3">
                                    <a href="@modul.Link" class="btn btn-outline-secondary btn-sm">@modul.LinkMetni</a>
                                </div>
                            </article>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="pc-panel h-100">
                <div class="pc-panel__header">
                    <div>
                        <h2 class="pc-panel__title">Canlı akış</h2>
                        <p class="pc-panel__subtitle mb-0">Modüller arası son hareketler ve kalite notları.</p>
                    </div>
                </div>
                <div class="pc-panel__body">
                    <div class="pc-timeline">
                        @foreach (var olay in Model.ZamanAkisi)
                        {
                            <article class="pc-timeline__item">
                                <div class="pc-timeline__icon"><i class="bx @olay.Ikon"></i></div>
                                <div class="pc-timeline__body">
                                    <div class="d-flex flex-column flex-md-row justify-content-md-between gap-2">
                                        <div>
                                            <div class="fw-semibold mb-1">@olay.Baslik</div>
                                            <p class="text-muted mb-0">@olay.Aciklama</p>
                                        </div>
                                        <span class="pc-timeline__time">@olay.Zaman</span>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pc-panel">
        <div class="pc-panel__header">
            <div>
                <h2 class="pc-panel__title">Hızlı geçişler</h2>
                <p class="pc-panel__subtitle mb-0">En sık kullanılan yönetim yüzeylerine doğrudan erişim.</p>
            </div>
        </div>
        <div class="pc-panel__body">
            <div class="pc-grid-auto">
                @foreach (var baglanti in Model.HizliBaglantilar)
                {
                    <a href="@baglanti.Link" class="pc-module-card text-decoration-none">
                        <div class="d-flex align-items-start gap-3">
                            <span class="pc-kpi-card__icon"><i class="bx @baglanti.Ikon"></i></span>
                            <div>
                                <div class="fw-semibold text-dark mb-1">@baglanti.Baslik</div>
                                <div class="text-muted">@baglanti.Ozet</div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </div>
    </section>
</div>
