@{
    ViewData["Title"] = "Butonlar - Arayüz Öğeleri";
}
@* ************** Content ************** *@
<div class="row g-6">
    <!-- Temel Butonlar -->
    <div class="col-12">
        <div class="card">
            <h5 class="card-header">Temel Butonlar</h5>
            <div class="card-body">
                <small class="fw-medium">Varsayılan</small>
                <div class="demo-inline-spacing">
                    <button type="button" class="btn btn-primary">Birincil</button>
                    <button type="button" class="btn btn-secondary">İkincil</button>
                    <button type="button" class="btn btn-success">Başarılı</button>
                    <button type="button" class="btn btn-danger">Hata</button>
                    <button type="button" class="btn btn-warning">Uyarı</button>
                    <button type="button" class="btn btn-info">Bilgi</button>
                    <button type="button" class="btn btn-dark">Koyu</button>
                </div>
            </div>
            <hr class="m-0" />
            <div class="card-body">
                <small class="fw-medium">Oval (Yuvarlatılmış)</small>
                <div class="demo-inline-spacing">
                    <button type="button" class="btn rounded-pill btn-primary">Birincil</button>
                    <button type="button" class="btn rounded-pill btn-secondary">İkincil</button>
                    <button type="button" class="btn rounded-pill btn-success">Başarılı</button>
                    <button type="button" class="btn rounded-pill btn-danger">Hata</button>
                    <button type="button" class="btn rounded-pill btn-warning">Uyarı</button>
                    <button type="button" class="btn rounded-pill btn-info">Bilgi</button>
                    <button type="button" class="btn rounded-pill btn-dark">Koyu</button>
                </div>
            </div>
        </div>
    </div>
    <!-- /Temel Butonlar -->
    <!-- Konturlu Butonlar -->
    <div class="col-12">
        <div class="card">
            <h5 class="card-header">Konturlu Butonlar</h5>
            <div class="card-body">
                <small class="fw-medium">Varsayılan</small>
                <div class="demo-inline-spacing">
                    <button type="button" class="btn btn-outline-primary">Birincil</button>
                    <button type="button" class="btn btn-outline-secondary">İkincil</button>
                    <button type="button" class="btn btn-outline-success">Başarılı</button>
                    <button type="button" class="btn btn-outline-danger">Hata</button>
                    <button type="button" class="btn btn-outline-warning">Uyarı</button>
                    <button type="button" class="btn btn-outline-info">Bilgi</button>
                    <button type="button" class="btn btn-outline-dark">Koyu</button>
                </div>
            </div>
            <hr class="m-0" />
            <div class="card-body">
                <small class="fw-medium">Oval (Yuvarlatılmış)</small>
                <div class="demo-inline-spacing">
                    <button type="button" class="btn rounded-pill btn-outline-primary">Birincil</button>
                    <button type="button" class="btn rounded-pill btn-outline-secondary">İkincil</button>
                    <button type="button" class="btn rounded-pill btn-outline-success">Başarılı</button>
                    <button type="button" class="btn rounded-pill btn-outline-danger">Hata</button>
                    <button type="button" class="btn rounded-pill btn-outline-warning">Uyarı</button>
                    <button type="button" class="btn rounded-pill btn-outline-info">Bilgi</button>
                    <button type="button" class="btn rounded-pill btn-outline-dark">Koyu</button>
                </div>
            </div>
        </div>
    </div>
    <!-- /Konturlu Butonlar -->
    <!-- İkonlu Butonlar -->
    <div class="col-12">
        <div class="card">
            <h5 class="card-header">İkonlu Butonlar</h5>
            <div class="card-body">
                <div class="row gy-3">
                    <div class="col-lg-4">
                        <small class="fw-medium">Temel</small>
                        <div class="demo-inline-spacing">
                            <button type="button" class="btn btn-primary">
                                <span class="icon-base bx bx-pie-chart-alt icon-sm me-2"></span>Birincil
                            </button>
                            <button type="button" class="btn btn-secondary">
                                <span class="icon-base bx bx-bell icon-sm me-2"></span>İkincil
                            </button>
                        </div>
                        <div class="demo-inline-spacing">
                            <button type="button" class="btn rounded-pill btn-primary">
                                <span class="icon-base bx bx-pie-chart-alt icon-sm me-2"></span>Birincil
                            </button>
                            <button type="button" class="btn rounded-pill btn-secondary">
                                <span class="icon-base bx bx-bell icon-sm me-2"></span>İkincil
                            </button>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <small class="fw-medium">Konturlu</small>
                        <div class="demo-inline-spacing">
                            <button type="button" class="btn btn-outline-primary">
                                <span class="icon-base bx bx-pie-chart-alt icon-sm me-2"></span>Birincil
                            </button>
                            <button type="button" class="btn btn-outline-secondary">
                                <span class="icon-base bx bx-bell icon-sm me-2"></span>İkincil
                            </button>
                        </div>
                        <div class="demo-inline-spacing">
                            <button type="button" class="btn rounded-pill btn-outline-primary">
                                <span class="icon-base bx bx-pie-chart-alt icon-sm me-2"></span>Birincil
                            </button>
                            <button type="button" class="btn rounded-pill btn-outline-secondary">
                                <span class="icon-base bx bx-bell icon-sm me-2"></span>İkincil
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <hr class="m-0" />
            <div class="card-body">
                <div class="row gy-3">
                    <div class="col-lg-4">
                        <small class="fw-medium">Temel ikon butonlar</small>
                        <div class="demo-inline-spacing">
                            <button type="button" class="btn btn-icon btn-primary">
                                <span class="icon-base bx bx-pie-chart-alt icon-md"></span>
                            </button>
                            <button type="button" class="btn btn-icon btn-secondary">
                                <span class="icon-base bx bx-bell icon-md"></span>
                            </button>
                            <button type="button" class="btn rounded-pill btn-icon btn-primary">
                                <span class="icon-base bx bx-pie-chart-alt icon-md"></span>
                            </button>
                            <button type="button" class="btn rounded-pill btn-icon btn-secondary">
                                <span class="icon-base bx bx-bell icon-md"></span>
                            </button>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <small class="fw-medium">Konturlu ikon butonlar</small>
                        <div class="demo-inline-spacing">
                            <button type="button" class="btn btn-icon btn-outline-primary">
                                <span class="icon-base bx bx-pie-chart-alt icon-md"></span>
                            </button>
                            <button type="button" class="btn btn-icon btn-outline-secondary">
                                <span class="icon-base bx bx-bell icon-md"></span>
                            </button>
                            <button type="button" class="btn rounded-pill btn-icon btn-outline-primary">
                                <span class="icon-base bx bx-pie-chart-alt icon-md"></span>
                            </button>
                            <button type="button" class="btn rounded-pill btn-icon btn-outline-secondary">
                                <span class="icon-base bx bx-bell icon-md"></span>
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
    <!-- /İkonlu Butonlar -->
    <!-- Buton Seçenekleri -->
    <div class="col-12">
        <div class="card">
            <h5 class="card-header">Buton Seçenekleri</h5>
            <div class="card-body">
                <small class="fw-medium">Boyutlar</small>
                <div class="demo-inline-spacing">
                    <button type="button" class="btn btn-xl btn-primary">XL Buton</button>
                    <button type="button" class="btn btn-lg btn-primary">Büyük Buton</button>
                    <button type="button" class="btn btn-primary">Buton</button>
                    <button type="button" class="btn btn-sm btn-primary">Küçük Buton</button>
                    <button type="button" class="btn btn-xs btn-primary">XS Buton</button>
                </div>
            </div>
            <hr class="m-0" />
            <div class="card-body">
                <small class="fw-medium">Buton Durumları</small>
                <div class="demo-inline-spacing">
                    <button type="button" class="btn btn-primary">Normal</button>
                    <button type="button" class="btn btn-primary active">Aktif</button>
                    <button type="button" class="btn btn-primary" disabled>Devre Dışı</button>
                </div>
            </div>
            <hr class="m-0" />
            <div class="card-body">
                <small class="fw-medium">Tam Genişlik (Blok) Butonlar</small>
                <div class="row mt-4">
                    <div class="d-grid gap-2 col-lg-6 mx-auto">
                        <button class="btn btn-primary btn-lg" type="button">Buton</button>
                        <button class="btn btn-secondary btn-lg" type="button">Buton</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- /Buton Seçenekleri -->
    <!-- Buton Eklentisi -->
    <div class="col-12">
        <div class="card">
            <h5 class="card-header">Buton Eklentisi</h5>
            <div class="card-body">
                <div class="row gy-3">
                    <div class="col-xl-3">
                        <div class="small fw-medium">Geçiş (Toggle) Durumları</div>
                        <div class="demo-vertical-spacing">
                            <button type="button" class="btn btn-primary d-block" data-bs-toggle="button">Geçişli Buton</button>
                            <button type="button" class="btn btn-primary active d-block" data-bs-toggle="button" aria-pressed="true">
                                Aktif Geçişli Buton
                            </button>
                            <button type="button" class="btn btn-primary d-block" disabled data-bs-toggle="button">
                                Devre Dışı Geçişli Buton
                            </button>
                        </div>
                    </div>

                    <div class="col-xl-3">
                        <div class="small fw-medium">Onay Kutulu Geçişli Butonlar</div>
                        <div class="demo-vertical-spacing">
                            <div class="d-block">
                                <input type="checkbox" class="btn-check" id="btn-check" />
                                <label class="btn btn-primary" for="btn-check">Tekli Geçiş</label>
                            </div>
                            <div class="d-block">
                                <input type="checkbox" class="btn-check" id="btn-check-2" checked />
                                <label class="btn btn-primary" for="btn-check-2">Seçili</label>
                            </div>
                            <div class="d-block">
                                <input type="checkbox" class="btn-check" id="btn-check-3" checked />
                                <label class="btn btn-primary" for="btn-check-3">Seçili</label>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-6">
                        <div class="small fw-medium">Onay Kutusu ve Seçenek (Radio)</div>
                        <div class="demo-vertical-spacing">
                            <!-- Checkbox -->
                            <div class="btn-group" role="group" aria-label="Temel onay kutusu geçişli buton grubu">
                                <input type="checkbox" class="btn-check" id="btncheck1" checked />
                                <label class="btn btn-outline-primary d-flex flex-column" for="btncheck1">
                                    <span class="d-none d-sm-block">Onay Kutusu</span>1 (önceden seçili)
                                </label>

                                <input type="checkbox" class="btn-check" id="btncheck2" />
                                <label class="btn btn-outline-primary d-flex flex-column" for="btncheck2">
                                    <span class="d-none d-sm-block">Onay Kutusu</span>2
                                </label>

                                <input type="checkbox" class="btn-check" id="btncheck3" />
                                <label class="btn btn-outline-primary d-flex flex-column" for="btncheck3">
                                    <span class="d-none d-sm-block">Onay Kutusu</span>3
                                </label>
                            </div>
                            <br />
                            <!-- Radio -->
                            <div class="btn-group" role="group" aria-label="Temel seçenek (radio) geçişli buton grubu">
                                <input type="radio" class="btn-check" name="btnradio" id="btnradio1" checked />
                                <label class="btn btn-outline-primary" for="btnradio1">Seçenek 1</label>

                                <input type="radio" class="btn-check" name="btnradio" id="btnradio2" />
                                <label class="btn btn-outline-primary" for="btnradio2">Seçenek 2</label>

                                <input type="radio" class="btn-check" name="btnradio" id="btnradio3" />
                                <label class="btn btn-outline-primary" for="btnradio3">Seçenek 3</label>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
    <!-- /Buton Eklentisi -->
    <!-- Buton Grupları -->
    <div class="col-12">
        <div class="card">
            <h5 class="card-header">Buton Grupları</h5>
            <div class="card-body">
                <div class="row g-4">
                    <div class="col-md-6 col-lg-4">
                        <small class="fw-medium">Temel</small>
                        <div class="mt-4">
                            <div class="btn-group" role="group" aria-label="Temel örnek">
                                <button type="button" class="btn btn-secondary">Sol</button>
                                <button type="button" class="btn btn-secondary">Orta</button>
                                <button type="button" class="btn btn-secondary">Sağ</button>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-4">
                        <small class="fw-medium">Konturlu</small>
                        <div class="mt-4">
                            <div class="btn-group" role="group" aria-label="Temel örnek">
                                <button type="button" class="btn btn-outline-secondary">Sol</button>
                                <button type="button" class="btn btn-outline-secondary">Orta</button>
                                <button type="button" class="btn btn-outline-secondary">Sağ</button>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <hr class="m-0" />
            <div class="card-body">
                <div class="row">
                    <div class="col-xl-6 mb-xl-0 mb-4">
                        <small class="fw-medium">Buton Araç Çubuğu</small>
                        <div class="btn-toolbar demo-inline-spacing" role="toolbar" aria-label="Buton gruplu araç çubuğu">
                            <div class="btn-group" role="group" aria-label="Birinci grup">
                                <button type="button" class="btn btn-outline-secondary">
                                    <i class="icon-base bx bx-bell"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary">
                                    <i class="icon-base bx bx-task"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary">
                                    <i class="icon-base bx bx-check-shield"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary">
                                    <i class="icon-base bx bx-comment-dots"></i>
                                </button>
                            </div>

                            <div class="btn-group" role="group" aria-label="İkinci grup">
                                <button type="button" class="btn btn-outline-secondary">
                                    <i class="icon-base bx bx-bold"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary">
                                    <i class="icon-base bx bx-italic"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary">
                                    <i class="icon-base bx bx-underline"></i>
                                </button>
                            </div>

                            <div class="btn-group" role="group" aria-label="Üçüncü grup">
                                <button type="button" class="btn btn-outline-secondary">
                                    <i class="icon-base bx bx-volume-full"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-6">
                        <small class="fw-medium">İç İçe Butonlar</small>
                        <div class="mt-4">
                            <div class="btn-group" role="group" aria-label="Açılır menülü iç içe buton grubu">
                                <button type="button" class="btn btn-outline-secondary">
                                    <i class="icon-base bx bx-car"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary">
                                    <i class="icon-base bx bx-rocket"></i>
                                </button>
                                <button type="button" class="btn btn-outline-secondary">
                                    <i class="icon-base bx bx-bulb"></i>
                                </button>
                                <div class="btn-group" role="group">
                                    <button id="btnGroupDrop1"
                                            type="button"
                                            class="btn btn-outline-secondary dropdown-toggle"
                                            data-bs-toggle="dropdown"
                                            aria-haspopup="true"
                                            aria-expanded="false">
                                        Açılır Menü
                                    </button>
                                    <div class="dropdown-menu" aria-labelledby="btnGroupDrop1">
                                        <a class="dropdown-item" href="javascript:void(0);">Açılır menü bağlantısı</a>
                                        <a class="dropdown-item" href="javascript:void(0);">Açılır menü bağlantısı</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
    <!-- /Buton Grupları -->
</div>
