@{
    ViewData["Title"] = "Carousel - Arayüz öğeleri";
}

@* ************** İçerik ************** *@
<div class="row g-6">
    <!-- Bootstrap carousel (slayt gösterisi) -->
    <div class="col-md">
        <h5 class="mb-6">Bootstrap carousel</h5>

        <div id="carouselExample" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#carouselExample" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slayt 1"></button>
                <button type="button" data-bs-target="#carouselExample" data-bs-slide-to="1" aria-label="Slayt 2"></button>
                <button type="button" data-bs-target="#carouselExample" data-bs-slide-to="2" aria-label="Slayt 3"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img class="d-block w-100" src="~/img/elements/3.png" alt="Birinci slayt" />
                    <div class="carousel-caption d-none d-md-block">
                        <h3>Birinci slayt</h3>
                        <p>Bu, birinci slayt için örnek bir açıklama metnidir.</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img class="d-block w-100" src="~/img/elements/4.png" alt="İkinci slayt" />
                    <div class="carousel-caption d-none d-md-block">
                        <h3>İkinci slayt</h3>
                        <p>Bu, ikinci slayt için kısa bir açıklama örneğidir.</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img class="d-block w-100" src="~/img/elements/5.png" alt="Üçüncü slayt" />
                    <div class="carousel-caption d-none d-md-block">
                        <h3>Üçüncü slayt</h3>
                        <p>Bu alan, üçüncü slayt için açıklama metni olarak kullanılabilir.</p>
                    </div>
                </div>
            </div>
            <a class="carousel-control-prev" href="#carouselExample" role="button" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Önceki</span>
            </a>
            <a class="carousel-control-next" href="#carouselExample" role="button" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Sonraki</span>
            </a>
        </div>
    </div>
    <!-- Bootstrap geçişli (crossfade) carousel (koyu tema) -->
    <div class="col-md">
        <h5 class="mb-6">Bootstrap geçişli carousel (koyu)</h5>

        <div id="carouselExampleDark" class="carousel carousel-dark slide carousel-fade" data-bs-ride="carousel">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#carouselExampleDark" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slayt 1"></button>
                <button type="button" data-bs-target="#carouselExampleDark" data-bs-slide-to="1" aria-label="Slayt 2"></button>
                <button type="button" data-bs-target="#carouselExampleDark" data-bs-slide-to="2" aria-label="Slayt 3"></button>
            </div>
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <img class="d-block w-100" src="~/img/elements/7.png" alt="Birinci slayt" />
                    <div class="carousel-caption d-none d-md-block">
                        <h3>Birinci slayt</h3>
                        <p>Bu, birinci slayt için örnek bir açıklama metnidir.</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img class="d-block w-100" src="~/img/elements/8.png" alt="İkinci slayt" />
                    <div class="carousel-caption d-none d-md-block">
                        <h3>İkinci slayt</h3>
                        <p>Bu, ikinci slayt için kısa bir açıklama örneğidir.</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img class="d-block w-100" src="~/img/elements/10.png" alt="Üçüncü slayt" />
                    <div class="carousel-caption d-none d-md-block">
                        <h3>Üçüncü slayt</h3>
                        <p>Bu alan, üçüncü slayt için açıklama metni olarak kullanılabilir.</p>
                    </div>
                </div>
            </div>
            <a class="carousel-control-prev" href="#carouselExampleDark" role="button" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Önceki</span>
            </a>
            <a class="carousel-control-next" href="#carouselExampleDark" role="button" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Sonraki</span>
            </a>
        </div>
    </div>
</div>
