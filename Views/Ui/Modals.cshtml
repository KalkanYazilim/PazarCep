@{
    ViewData["Title"] = "Modallar - Arayüz öğeleri";
}

@section PageScripts {
    <script src="~/js/ui-modals.js"></script>
}
@* ************** İçerik ************** *@
<div class="row gy-6">
    <!-- Bootstrap modallar -->
    <div class="col-lg-12">
        <div class="card">
            <h5 class="card-header">Bootstrap modallar</h5>
            <div class="card-body">
                <div class="row gy-3">
                    <!-- Varsayılan Modal -->
                    <div class="col-lg-4 col-md-6">
                        <small class="fw-medium">Varsayılan</small>
                        <div class="mt-4">
                            <!-- Buton ile modal aç -->
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#basicModal">Modali aç</button>

                            <!-- Modal -->
                            <div class="modal fade" id="basicModal" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog" role="document">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="exampleModalLabel1">Modal başlığı</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="row">
                                                <div class="col mb-6">
                                                    <label for="nameBasic" class="form-label">Ad</label>
                                                    <input type="text" id="nameBasic" name="nameBasic" class="form-control" placeholder="Ad girin" />
                                                </div>
                                            </div>
                                            <div class="row g-6">
                                                <div class="col mb-0">
                                                    <label for="emailBasic" class="form-label">E-posta</label>
                                                    <input type="email" id="emailBasic" name="emailBasic" class="form-control" placeholder="ornek&#64;domain.com" />
                                                </div>
                                                <div class="col mb-0">
                                                    <label for="dobBasic" class="form-label">Doğum Tarihi</label>
                                                    <input type="date" id="dobBasic" name="dobBasic" class="form-control" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Kapat</button>
                                            <button type="button" class="btn btn-primary">Değişiklikleri kaydet</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Dikey ortalanmış Modal -->
                    <div class="col-lg-4 col-md-6">
                        <small class="fw-medium">Dikey ortalanmış</small>
                        <div class="mt-4">
                            <!-- Buton ile modal aç -->
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCenter">Modali aç</button>

                            <!-- Modal -->
                            <div class="modal fade" id="modalCenter" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered" role="document">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="modalCenterTitle">Modal başlığı</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="row">
                                                <div class="col mb-6">
                                                    <label for="nameWithTitle" class="form-label">Ad</label>
                                                    <input type="text" id="nameWithTitle" name="nameWithTitle" class="form-control" placeholder="Ad girin" />
                                                </div>
                                            </div>
                                            <div class="row g-6">
                                                <div class="col mb-0">
                                                    <label for="emailWithTitle" class="form-label">E-posta</label>
                                                    <input type="email" id="emailWithTitle" name="emailWithTitle" class="form-control" placeholder="ornek&#64;domain.com" />
                                                </div>
                                                <div class="col mb-0">
                                                    <label for="dobWithTitle" class="form-label">Doğum Tarihi</label>
                                                    <input type="date" id="dobWithTitle" name="dobWithTitle" class="form-control" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Kapat</button>
                                            <button type="button" class="btn btn-primary">Değişiklikleri kaydet</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Üstten kayan Modal -->
                    <div class="col-lg-4 col-md-6">
                        <small class="fw-medium">Yukarıdan kayan</small>
                        <div class="mt-4">
                            <!-- Buton ile modal aç -->
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalTop">Modali aç</button>

                            <!-- Modal -->
                            <div class="modal modal-top fade" id="modalTop" tabindex="-1">
                                <div class="modal-dialog">
                                    <form class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="modalTopTitle">Modal başlığı</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="row">
                                                <div class="col mb-6">
                                                    <label for="nameSlideTop" class="form-label">Ad</label>
                                                    <input type="text" id="nameSlideTop" name="nameSlideTop" class="form-control" placeholder="Ad girin" />
                                                </div>
                                            </div>
                                            <div class="row g-6">
                                                <div class="col mb-0">
                                                    <label for="emailSlideTop" class="form-label">E-posta</label>
                                                    <input type="email" id="emailSlideTop" name="emailSlideTop" class="form-control" placeholder="ornek&#64;domain.com" />
                                                </div>
                                                <div class="col mb-0">
                                                    <label for="dobSlideTop" class="form-label">Doğum Tarihi</label>
                                                    <input type="date" id="dobSlideTop" name="dobSlideTop" class="form-control" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Kapat</button>
                                            <button type="button" class="btn btn-primary">Kaydet</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <hr class="m-0" />
            <div class="card-body">
                <div class="row gy-3">
                    <!-- YouTube Videolu Modal -->
                    <div class="col-lg-4 col-md-6">
                        <small class="fw-medium">YouTube Videosu</small>
                        <div class="mt-4">
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#youTubeModal" data-theVideo="https://www.youtube.com/embed/EngW7tLk6R8">Modali aç</button>

                            <!-- Modal -->
                            <div class="modal fade" id="youTubeModal" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog" role="document">
                                    <div class="modal-content">
                                        <iframe height="350" src="https://www.youtube.com/embed/EngW7tLk6R8"></iframe>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Modallar Arasında Geçiş -->
                    <div class="col-lg-4 col-md-6">
                        <small class="fw-medium">Modallar Arasında Geçiş</small>
                        <div class="mt-4">
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalToggle">Modali aç</button>

                            <!-- Modal 1-->
                            <div class="modal fade" id="modalToggle" aria-labelledby="modalToggleLabel" tabindex="-1" style="display: none;" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="modalToggleLabel">Modal 1</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                        </div>
                                        <div class="modal-body">Aşağıdaki buton ile bu modali gizleyip ikinci modali gösterebilirsiniz.</div>
                                        <div class="modal-footer">
                                            <button class="btn btn-primary" data-bs-target="#modalToggle2" data-bs-toggle="modal" data-bs-dismiss="modal">İkinci modali aç</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Modal 2-->
                            <div class="modal fade" id="modalToggle2" aria-hidden="true" aria-labelledby="modalToggleLabel2" tabindex="-1">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="modalToggleLabel2">Modal 2</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                        </div>
                                        <div class="modal-body">Aşağıdaki buton ile bu modali gizleyip ilk modale geri dönebilirsiniz.</div>
                                        <div class="modal-footer">
                                            <button class="btn btn-primary" data-bs-target="#modalToggle" data-bs-toggle="modal" data-bs-dismiss="modal">İlk modale dön</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Tam ekran Modal -->
                    <div class="col-lg-4 col-md-6">
                        <small class="fw-medium">Tam ekran</small>
                        <div class="mt-4">
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#fullscreenModal">Modali aç</button>

                            <!-- Modal -->
                            <div class="modal fade" id="fullscreenModal" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-fullscreen" role="document">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="modalFullTitle">Modal başlığı</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                        </div>
                                        <div class="modal-body">
                                            <p>Bu alan, uzun içeriklerin tam ekran bir modal içinde nasıl görüneceğini test etmek için kullanılan örnek paragraftır.</p>
                                            <p>Farklı paragraf yapıları ve satır uzunlukları, kaydırma davranışını ve okunabilirliği denemek için kullanılabilir.</p>
                                            <p>Uygulamanızda yardım metinleri, şartlar ve koşullar veya detaylı formlar göstermek için tam ekran modallar tercih edilebilir.</p>
                                            <p>Buradaki metinlerin tamamı sadece örnek amaçlıdır ve gerçek veri içermez.</p>
                                            <p>Bu sayede tasarım, tipografi ve boşluklandırma ayarlarını son kullanıcıya geçmeden önce kontrol edebilirsiniz.</p>
                                            <p>İçeriği projeye göre özelleştirerek, kullanıcılarınıza daha açıklayıcı ve anlaşılır açıklamalar sağlayabilirsiniz.</p>
                                            <p>Bu paragraf da test amaçlı eklenmiştir ve uzun içeriklerin sayfa yapısı üzerindeki etkisini görmek için kullanılabilir.</p>
                                            <p>Gerekli durumlarda listeler, görseller veya tablolar da bu modal içerisine dahil edilebilir.</p>
                                            <p>Bu şekilde, modal pencereler hem basit bildirimler hem de karmaşık içerikler için esnek bir alan sunar.</p>
                                            <p>Metin uzunluğunu artırarak dikey kaydırma çubuklarının davranışını da gözlemleyebilirsiniz.</p>
                                            <p>Buraya, hukuki metinler, kullanım şartları veya KVKK metinleri gibi resmi içerikler de eklenebilir.</p>
                                            <p>Son kullanıcı deneyimini iyileştirmek için başlıklar, alt başlıklar ve paragraflar arasında yeterli boşluk bırakmayı unutmayın.</p>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Kapat</button>
                                            <button type="button" class="btn btn-primary">Değişiklikleri kaydet</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <hr class="m-0" />
            <div class="card-body">
                <div class="row gy-3">
                    <!-- Modal Boyutları -->
                    <div class="col-lg-4 col-md-6">
                        <small class="fw-medium">Boyutlar</small>
                        <!-- Küçük Modal -->
                        <div class="modal fade" id="smallModal" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-sm" role="document">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="exampleModalLabel2">Modal başlığı</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="row">
                                            <div class="col mb-6">
                                                <label for="nameSmall" class="form-label">Ad</label>
                                                <input type="text" id="nameSmall" name="nameSmall" class="form-control" placeholder="Ad girin" />
                                            </div>
                                        </div>
                                        <div class="row g-6">
                                            <div class="col mb-0">
                                                <label class="form-label" for="emailSmall">E-posta</label>
                                                <input type="email" class="form-control" id="emailSmall" name="emailSmall" placeholder="ornek&#64;domain.com" />
                                            </div>
                                            <div class="col mb-0">
                                                <label for="dobSmall" class="form-label">Doğum Tarihi</label>
                                                <input id="dobSmall" name="dobSmall" type="date" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Kapat</button>
                                        <button type="button" class="btn btn-primary">Değişiklikleri kaydet</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Büyük Modal -->
                        <div class="modal fade" id="largeModal" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-lg" role="document">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="exampleModalLabel3">Modal başlığı</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="row">
                                            <div class="col mb-6">
                                                <label for="nameLarge" class="form-label">Ad</label>
                                                <input type="text" id="nameLarge" name="nameLarge" class="form-control" placeholder="Ad girin" />
                                            </div>
                                        </div>
                                        <div class="row g-6">
                                            <div class="col mb-0">
                                                <label for="emailLarge" class="form-label">E-posta</label>
                                                <input type="email" id="emailLarge" name="emailLarge" class="form-control" placeholder="ornek&#64;domain.com" />
                                            </div>
                                            <div class="col mb-0">
                                                <label for="dobLarge" class="form-label">Doğum Tarihi</label>
                                                <input type="date" id="dobLarge" name="dobLarge" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Kapat</button>
                                        <button type="button" class="btn btn-primary">Değişiklikleri kaydet</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Çok Büyük Modal -->
                        <div class="modal fade" id="exLargeModal" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-xl" role="document">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="exampleModalLabel4">Modal başlığı</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                    </div>
                                    <div class="modal-body">
                                        <div class="row">
                                            <div class="col mb-6">
                                                <label for="nameExLarge" class="form-label">Ad</label>
                                                <input type="text" id="nameExLarge" name="nameExLarge" class="form-control" placeholder="Ad girin" />
                                            </div>
                                        </div>
                                        <div class="row g-6">
                                            <div class="col mb-0">
                                                <label for="emailExLarge" class="form-label">E-posta</label>
                                                <input type="email" id="emailExLarge" name="emailExLarge" class="form-control" placeholder="ornek&#64;domain.com" />
                                            </div>
                                            <div class="col mb-0">
                                                <label for="dobExLarge" class="form-label">Doğum Tarihi</label>
                                                <input type="date" id="dobExLarge" name="dobExLarge" class="form-control" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Kapat</button>
                                        <button type="button" class="btn btn-primary">Değişiklikleri kaydet</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="demo-inline-spacing">
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#smallModal">Küçük</button>

                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#largeModal">Büyük</button>

                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#exLargeModal">Çok Büyük</button>
                        </div>
                    </div>

                    <!-- Uzun kaydırmalı içerik Modal -->
                    <div class="col-lg-4 col-md-3">
                        <small class="fw-medium">Uzun içerik kaydırma</small>
                        <!-- Modal -->
                        <div class="modal fade" id="modalLong" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog" role="document">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="modalLongTitle">Modal başlığı</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                    </div>
                                    <div class="modal-body">
                                        <p>Bu modal, çok sayıda paragraf içeren uzun metinler için kaydırma davranışını test etmek amacıyla hazırlanmıştır.</p>
                                        <p>Kullanıcılar, içerik alanında aşağı ve yukarı kaydırma yaparak tüm metni okuyabilirler.</p>
                                        <p>Buraya kullanım şartları, sözleşmeler veya detaylı yardım metinleri eklenebilir.</p>
                                        <p>Bu paragraflar sadece örnek niteliğindedir ve gerçek içerik yerine tasarım testine hizmet eder.</p>
                                        <p>Metin uzunluğu artırıldıkça kaydırma alanı da büyür ve kullanıcı deneyimi daha net gözlemlenebilir.</p>
                                        <p>Farklı ekran boyutlarında bu modalın nasıl göründüğünü test etmek önemlidir.</p>
                                        <p>Responsive tasarım sayesinde modal küçük ekranlarda da düzgün bir şekilde görüntülenecektir.</p>
                                        <p>Gerektiğinde bu alana listeler, görseller veya formlar da dahil edilebilir.</p>
                                        <p>Kullanıcıların odaklanması gereken önemli noktalar için başlık ve kalın metin kullanabilirsiniz.</p>
                                        <p>Bu örnek, gerçek projede yer alacak metinler ile kolayca değiştirilebilir.</p>
                                        <p>Kaydırma davranışını test etmek için burada fazladan satırlar bulundurulmuştur.</p>
                                        <p>Son kullanıcıya sunmadan önce bu alanları kendi iş kurallarınıza göre uyarlamanız gerekir.</p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Kapat</button>
                                        <button type="button" class="btn btn-primary">Değişiklikleri kaydet</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Kaydırmalı Modal -->
                        <div class="modal fade" id="modalScrollable" tabindex="-1" aria-hidden="true">
                            <div class="modal-dialog modal-dialog-scrollable" role="document">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="modalScrollableTitle">Modal başlığı</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                    </div>
                                    <div class="modal-body">
                                        <p>Bu modal, sadece içerik alanı kaydırılabilir olacak şekilde yapılandırılmıştır.</p>
                                        <p>Başlık ve alt kısım sabit kalırken, kullanıcı orta alandaki uzun metni kaydırarak okuyabilir.</p>
                                        <p>Bu tür modallar, formlar veya çok adımlı açıklamalar için oldukça kullanışlıdır.</p>
                                        <p>Tasarım testleri sırasında bu alanın dolu olması, gerçek senaryoları daha iyi simüle etmenizi sağlar.</p>
                                        <p>İçerik tamamen örnektir ve proje gereksinimlerinize göre değiştirilebilir.</p>
                                        <p>Kullanıcı deneyimini iyileştirmek için satır aralıklarını ve yazı boyutunu dikkatle seçmelisiniz.</p>
                                        <p>Buraya ekleyeceğiniz metinler, uygulamanın genel diline ve üslubuna uygun olmalıdır.</p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Kapat</button>
                                        <button type="button" class="btn btn-primary">Değişiklikleri kaydet</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="demo-inline-spacing">
                            <!-- Buton: modalLong -->
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalLong">Seçenek 1</button>

                            <!-- Buton: modalScrollable -->
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalScrollable">Seçenek 2</button>
                        </div>
                    </div>

                    <!-- Arka plan (Backdrop) Modal -->
                    <div class="col-lg-4 col-md-3">
                        <small class="fw-medium">Arka plan (backdrop)</small>
                        <div class="mt-4">
                            <!-- Buton ile modal aç -->
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#backDropModal">Modali aç</button>

                            <!-- Modal -->
                            <div class="modal fade" id="backDropModal" data-bs-backdrop="static" tabindex="-1">
                                <div class="modal-dialog">
                                    <form class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="backDropModalTitle">Modal başlığı</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                                        </div>
                                        <div class="modal-body">
                                            <div class="row">
                                                <div class="col mb-6">
                                                    <label for="nameBackdrop" class="form-label">Ad</label>
                                                    <input type="text" id="nameBackdrop" name="nameBackdrop" class="form-control" placeholder="Ad girin" />
                                                </div>
                                            </div>
                                            <div class="row g-6">
