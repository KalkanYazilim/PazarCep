@{
    ViewData["Title"] = "Liste Grupları - Arayüz öğeleri";
}
@* ************** İçerik ************** *@
<div class="row g-6">
    <div class="col-lg-12">
        <div class="card">
            <h5 class="card-header">Liste grupları</h5>
            <div class="card-body">
                <div class="row">
                    <!-- Temel Liste grubu -->
                    <div class="col-lg-6 mb-6 mb-xl-0">
                        <small class="fw-medium">Temel</small>
                        <div class="demo-inline-spacing mt-4">
                            <div class="list-group">
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action active">Ay çöreği kek bisküvi</a>
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action">Sufle hamurlu turta dondurma</a>
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action disabled">Tart tiramisu kek</a>
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action">Bonbon karamelli muffin</a>
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action">Draje tootsie şekerlemesi</a>
                            </div>
                        </div>
                    </div>
                    <!--/ Temel Liste grubu -->
                    <!-- Rozetli & Baloncuklu Liste grubu -->
                    <div class="col-lg-6">
                        <small class="fw-medium">Rozetler ve Baloncuklar ile</small>
                        <div class="demo-inline-spacing mt-4">
                            <ul class="list-group">
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    Sufle hamurlu turta dondurma
                                    <span class="badge bg-primary">5</span>
                                </li>
                                <li class="list-group-item disabled">Ay çöreği kek bisküvi</li>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    Tart tiramisu kek
                                    <span class="badge bg-success">2</span>
                                </li>
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    Bonbon karamelli muffin
                                    <span class="badge bg-danger rounded-pill">3</span>
                                </li>
                                <li class="list-group-item">Draje tootsie şekerlemesi</li>
                            </ul>
                        </div>
                    </div>
                    <!--/ Rozetli & Baloncuklu Liste grubu -->
                </div>
            </div>
            <hr class="m-0" />
            <div class="card-body">
                <div class="row">
                    <!-- Sınırları kaldırılmış (Flush) Liste grubu -->
                    <div class="col-lg-6 mb-6 mb-xl-0">
                        <small class="fw-medium">Sınırları kaldırılmış (Flush)</small>
                        <div class="demo-inline-spacing mt-4">
                            <div class="list-group list-group-flush">
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action">Ay çöreği kek bisküvi</a>
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action">Sufle hamurlu turta dondurma</a>
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action">Tart tiramisu kek</a>
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action">Bonbon karamelli muffin</a>
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action">Draje tootsie şekerlemesi</a>
                            </div>
                        </div>
                    </div>
                    <!--/ Sınırları kaldırılmış (Flush) Liste grubu -->
                    <!-- İkonlu Liste grubu -->
                    <div class="col-lg-6">
                        <small class="fw-medium">İkonlu</small>
                        <div class="demo-inline-spacing mt-4">
                            <ul class="list-group">
                                <li class="list-group-item d-flex align-items-center">
                                    <i class="icon-base bx bx-tv me-2"></i>
                                    Sufle hamurlu turta dondurma
                                </li>
                                <li class="list-group-item d-flex align-items-center">
                                    <i class="icon-base bx bx-bell me-2"></i>
                                    Ay çöreği kek bisküvi
                                </li>
                                <li class="list-group-item d-flex align-items-center">
                                    <i class="icon-base bx bx-support me-2"></i>
                                    Tart tiramisu kek
                                </li>
                                <li class="list-group-item d-flex align-items-center">
                                    <i class="icon-base bx bx-purchase-tag-alt me-2"></i>
                                    Bonbon karamelli muffin
                                </li>
                                <li class="list-group-item d-flex align-items-center">
                                    <i class="icon-base bx bx-closet me-2"></i>
                                    Draje tootsie şekerlemesi
                                </li>
                            </ul>
                        </div>
                    </div>
                    <!--/ İkonlu Liste grubu -->
                </div>
            </div>
            <hr class="m-0" />
            <div class="card-body">
                <div class="row">
                    <!-- Numaralı Liste grubu -->
                    <div class="col-lg-6 mb-6 mb-xl-0">
                        <small class="fw-medium">Numaralı</small>
                        <div class="demo-inline-spacing mt-4">
                            <ol class="list-group list-group-numbered">
                                <li class="list-group-item">Ay çöreği kek bisküvi</li>
                                <li class="list-group-item">Sufle hamurlu turta dondurma</li>
                                <li class="list-group-item">Tart tiramisu kek</li>
                                <li class="list-group-item">Bonbon karamelli muffin</li>
                                <li class="list-group-item">Draje tootsie şekerlemesi</li>
                            </ol>
                        </div>
                    </div>
                    <!--/ Numaralı Liste grubu -->
                    <!-- Onay kutulu Liste grubu -->
                    <div class="col-lg-6">
                        <small class="fw-medium">Onay Kutulu Liste grubu</small>
                        <div class="demo-inline-spacing mt-4">
                            <div class="list-group">
                                <label class="list-group-item">
                                    <input class="form-check-input me-1" type="checkbox" value="" />
                                    Sufle hamurlu turta dondurma
                                </label>
                                <label class="list-group-item">
                                    <input class="form-check-input me-1" type="checkbox" value="" />
                                    Ay çöreği kek bisküvi
                                </label>
                                <label class="list-group-item">
                                    <input class="form-check-input me-1" type="checkbox" value="" />
                                    Tart tiramisu kek
                                </label>
                                <label class="list-group-item">
                                    <input class="form-check-input me-1" type="checkbox" value="" />
                                    Bonbon karamelli muffin
                                </label>
                                <label class="list-group-item">
                                    <input class="form-check-input me-1" type="checkbox" value="" />
                                    Draje tootsie şekerlemesi
                                </label>
                            </div>
                        </div>
                    </div>
                    <!--/ Onay kutulu Liste grubu -->
                </div>
            </div>
            <hr class="m-0" />
            <div class="card-body">
                <div class="row">
                    <!-- Bağlamsal Liste grubu -->
                    <div class="col-lg-6 mb-6 mb-xl-0">
                        <small class="fw-medium">Bağlamsal sınıflar</small>
                        <div class="demo-inline-spacing mt-4">
                            <ul class="list-group">
                                <li class="list-group-item list-group-item-action list-group-item-primary">Birincil liste grubu öğesi</li>
                                <li class="list-group-item list-group-item-action list-group-item-secondary">İkincil liste grubu öğesi</li>
                                <li class="list-group-item list-group-item-action list-group-item-success">Başarılı liste grubu öğesi</li>
                                <li class="list-group-item list-group-item-action list-group-item-danger">Hata liste grubu öğesi</li>
                                <li class="list-group-item list-group-item-action list-group-item-warning">Uyarı liste grubu öğesi</li>
                                <li class="list-group-item list-group-item-action list-group-item-info">Bilgi liste grubu öğesi</li>
                                <li class="list-group-item list-group-item-action list-group-item-dark">Koyu liste grubu öğesi</li>
                            </ul>
                        </div>
                    </div>
                    <!--/ Bağlamsal Liste grubu -->
                    <!-- Başlıklı özel içerik -->
                    <div class="col-lg-6">
                        <small class="fw-medium">Özel içerik</small>
                        <div class="demo-inline-spacing mt-4">
                            <div class="list-group">
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action flex-column align-items-start active">
                                    <div class="d-flex justify-content-between w-100">
                                        <h4 class="mb-1">Liste grubu öğesi başlığı</h4>
                                        <small>3 gün önce</small>
                                    </div>
                                    <p class="mb-1">Bu, liste grubu bileşeninin görünümünü ve düzenini test etmek için kullanılan örnek bir açıklama metnidir.</p>
                                    <small>Bu satır ek açıklama amaçlıdır.</small>
                                </a>
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action flex-column align-items-start">
                                    <div class="d-flex justify-content-between w-100">
                                        <h4 class="mb-1">Liste grubu öğesi başlığı</h4>
                                        <small class="text-body-secondary">3 gün önce</small>
                                    </div>
                                    <p class="mb-1">Bu metin, liste grubu bileşeni için ikinci örnek içeriği temsil eder ve tasarım testi için kullanılır.</p>
                                    <small class="text-body-secondary">Bu satır ek açıklama amaçlıdır.</small>
                                </a>
                                <a href="javascript:void(0);" class="list-group-item list-group-item-action flex-column align-items-start">
                                    <div class="d-flex justify-content-between w-100">
                                        <h4 class="mb-1">Liste grubu öğesi başlığı</h4>
                                        <small class="text-body-secondary">3 gün önce</small>
                                    </div>
                                    <p class="mb-1">Bu örnek metin, daha uzun içeriklerin liste içerisinde nasıl göründüğünü göstermek için kullanılır.</p>
                                    <small class="text-body-secondary">Bu satır ek açıklama amaçlıdır.</small>
                                </a>
                            </div>
                        </div>
                    </div>
                    <!--/ Başlıklı özel içerik -->
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-12">
        <div class="card">
            <h5 class="card-header">JavaScript davranışı</h5>
            <div class="card-body">
                <div class="row">
                    <!-- Dikey sekmeli liste -->
                    <div class="col-lg-6 mb-6 mb-xl-0">
                        <small class="fw-medium">Dikey</small>
                        <div class="mt-4">
                            <div class="row">
                                <div class="col-md-4 col-12 mb-4 mb-md-0">
                                    <div class="list-group">
                                        <a class="list-group-item list-group-item-action active" id="list-home-list" data-bs-toggle="list" href="#list-home">Ana Sayfa</a>
                                        <a class="list-group-item list-group-item-action" id="list-profile-list" data-bs-toggle="list" href="#list-profile">Profil</a>
                                        <a class="list-group-item list-group-item-action" id="list-messages-list" data-bs-toggle="list" href="#list-messages">Mesajlar</a>
                                        <a class="list-group-item list-group-item-action" id="list-settings-list" data-bs-toggle="list" href="#list-settings">Ayarlar</a>
                                    </div>
                                </div>
                                <div class="col-md-8 col-12">
                                    <div class="tab-content p-0">
                                        <div class="tab-pane fade show active" id="list-home">
                                            Donut, şekerleme ve bisküvilerden oluşan örnek bir metindir. Arayüz bileşenlerinin yerleşimini ve yazı tipini test etmek için kullanılır.
                                        </div>
                                        <div class="tab-pane fade" id="list-profile">
                                            Profil sekmesi için kullanılan örnek açıklama metnidir. Farklı içeriklerin sekmeler arasında nasıl geçiş yaptığını göstermek için eklenmiştir.
                                        </div>
                                        <div class="tab-pane fade" id="list-messages">
                                            Mesajlar sekmesine ait örnek içeriktir. Kullanıcı iletişimlerini ya da bildirimlerini temsil eden sahte bir metin içermektedir.
                                        </div>
                                        <div class="tab-pane fade" id="list-settings">
                                            Ayarlar sekmesi için örnek bir metindir. Uygulama tercihleri ve yapılandırma ayarları gibi alanları temsil etmek için kullanılır.
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Yatay sekmeli liste -->
                    <div class="col-lg-6">
                        <small class="fw-medium">Yatay</small>
                        <div class="mt-4">
                            <div class="list-group list-group-horizontal-md text-md-center">
                                <a class="list-group-item list-group-item-action active" id="home-list-item" data-bs-toggle="list" href="#horizontal-home">Ana Sayfa</a>
                                <a class="list-group-item list-group-item-action" id="profile-list-item" data-bs-toggle="list" href="#horizontal-profile">Profil</a>
                                <a class="list-group-item list-group-item-action" id="messages-list-item" data-bs-toggle="list" href="#horizontal-messages">Mesajlar</a>
                                <a class="list-group-item list-group-item-action" id="settings-list-item" data-bs-toggle="list" href="#horizontal-settings">Ayarlar</a>
                            </div>
                            <div class="tab-content px-0 mt-0">
                                <div class="tab-pane fade show active" id="horizontal-home">
                                    Donut, şekerleme ve çöreklerden oluşan tatlı bir örnek metindir. Arayüzün farklı genişliklerde nasıl davrandığını görmek için kullanılır.
                                </div>
                                <div class="tab-pane fade" id="horizontal-profile">
                                    Profil sekmesi için ikinci bir örnek metindir. Burada profil bilgileri, avatar ve diğer kullanıcı detayları temsil edilmektedir.
                                </div>
                                <div class="tab-pane fade" id="horizontal-messages">
                                    Mesajlar sekmesi için oluşturulmuş sahte veri metnidir. Kullanıcı mesaj kutusu deneyimini test etmek amacıyla kullanılır.
                                </div>
                                <div class="tab-pane fade" id="horizontal-settings">
                                    Ayarlar sekmesi için eklenen metindir. Uygulama içi ayarların düzenlenmesini, tema ve bildirim seçeneklerini simüle eder.
                                </div>
                            </div>
                        </div>
                    </div>
                    <!--/ Yatay sekmeli liste -->
                </div>
            </div>
        </div>
    </div>
</div>
