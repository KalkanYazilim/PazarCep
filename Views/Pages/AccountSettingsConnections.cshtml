@{
    ViewData["Title"] = "Hesap Ayarları - Bağlantılar";
}

@* ************** Content ************** *@
<div class="row">
    <div class="col-md-12">
        <div class="nav-align-top">
            <ul class="nav nav-pills flex-column flex-md-row mb-6 gap-md-0 gap-2">
                <li class="nav-item">
                    <a class="nav-link" href="AccountSettings">
                        <i class="icon-base bx bx-user icon-sm me-1_5"></i> Hesap
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="AccountSettingsNotifications">
                        <i class="icon-base bx bx-bell icon-sm me-1_5"></i> Bildirimler
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" href="javascript:void(0);">
                        <i class="icon-base bx bx-link-alt icon-sm me-1_5"></i> Bağlantılar
                    </a>
                </li>
            </ul>
        </div>

        <div class="card">
            <div class="row">
                <!-- Connected Accounts -->
                <div class="col-md-6 col-12">
                    <div class="card-header">
                        <h5 class="mb-1">Bağlı Hesaplar</h5>
                        <p class="my-0 card-subtitle">
                            Bağladığınız hesaplardan gelen içerikleri PazarCep içerisinde görüntüleyin.
                        </p>
                    </div>
                    <div class="card-body">
                        <div class="d-flex mb-4 align-items-center">
                            <div class="flex-shrink-0">
                                <img src="~/img/icons/brands/google.png" alt="google" class="me-4" height="32" />
                            </div>
                            <div class="flex-grow-1 d-flex align-items-center justify-content-between">
                                <div class="mb-sm-0 mb-2">
                                    <h6 class="mb-0">Google</h6>
                                    <small>Takvim ve kişiler</small>
                                </div>
                                <div class="text-end">
                                    <div class="form-check form-switch mb-0">
                                        <input type="checkbox" id="connectedGoogle" name="connectedGoogle" class="form-check-input" aria-label="Google bağlantısını etkinleştir" checked />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex mb-4 align-items-center">
                            <div class="flex-shrink-0">
                                <img src="~/img/icons/brands/slack.png" alt="slack" class="me-4" height="32" />
                            </div>
                            <div class="flex-grow-1 d-flex align-items-center justify-content-between">
                                <div class="mb-sm-0 mb-2">
                                    <h6 class="mb-0">Slack</h6>
                                    <small>İletişim</small>
                                </div>
                                <div class="text-end">
                                    <div class="form-check form-switch mb-0">
                                        <input type="checkbox" id="connectedSlack" name="connectedSlack" class="form-check-input" aria-label="Slack bağlantısını etkinleştir" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex mb-4 align-items-center">
                            <div class="flex-shrink-0">
                                <img src="~/img/icons/brands/github.png" alt="github" class="me-4" height="32" />
                            </div>
                            <div class="flex-grow-1 d-flex align-items-center justify-content-between">
                                <div class="mb-sm-0 mb-2">
                                    <h6 class="mb-0">GitHub</h6>
                                    <small>Git depolarınızı yönetin</small>
                                </div>
                                <div class="text-end">
                                    <div class="form-check form-switch mb-0">
                                        <input type="checkbox" id="connectedGithub" name="connectedGithub" class="form-check-input" aria-label="GitHub bağlantısını etkinleştir" checked />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex mb-4 align-items-center">
                            <div class="flex-shrink-0">
                                <img src="~/img/icons/brands/mailchimp.png" alt="mailchimp" class="me-4" height="32" />
                            </div>
                            <div class="flex-grow-1 d-flex align-items-center justify-content-between">
                                <div class="mb-sm-0 mb-2">
                                    <h6 class="mb-0">Mailchimp</h6>
                                    <small>E-posta pazarlama servisi</small>
                                </div>
                                <div class="text-end">
                                    <div class="form-check form-switch mb-0">
                                        <input type="checkbox" id="connectedMailchimp" name="connectedMailchimp" class="form-check-input" aria-label="Mailchimp bağlantısını etkinleştir" checked />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <img src="~/img/icons/brands/asana.png" alt="asana" class="me-4" height="32" />
                            </div>
                            <div class="flex-grow-1 d-flex align-items-center justify-content-between">
                                <div class="mb-sm-0 mb-2">
                                    <h6 class="mb-0">Asana</h6>
                                    <small>Görev ve proje yönetimi</small>
                                </div>
                                <div class="text-end">
                                    <div class="form-check form-switch mb-0">
                                        <input type="checkbox" id="connectedAsana" name="connectedAsana" class="form-check-input" aria-label="Asana bağlantısını etkinleştir" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- /Connections -->
                    </div>
                </div>

                <!-- Social Accounts -->
                <div class="col-md-6 col-12">
                    <div class="card-header">
                        <h5 class="mb-1">Sosyal Hesaplar</h5>
                        <p class="my-0 card-subtitle">
                            Sosyal medya hesaplarınızdan içerikleri PazarCep üzerinde de gösterin.
                        </p>
                    </div>
                    <div class="card-body">

                        <div class="d-flex mb-4 align-items-center">
                            <div class="flex-shrink-0">
                                <img src="~/img/icons/brands/facebook.png" alt="facebook" class="me-4" height="32" />
                            </div>
                            <div class="flex-grow-1 row">
                                <div class="col-7">
                                    <h6 class="mb-0">Facebook</h6>
                                    <small>Bağlı değil</small>
                                </div>
                                <div class="col-5 text-end mt-sm-0 mt-2">
                                    <button class="btn btn-icon btn-outline-secondary">
                                        <i class="icon-base bx bx-link icon-md"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex mb-4 align-items-center">
                            <div class="flex-shrink-0">
                                <img src="~/img/icons/brands/twitter.png" alt="twitter" class="me-4" height="32" />
                            </div>
                            <div class="flex-grow-1 row">
                                <div class="col-7">
                                    <h6 class="mb-0">Twitter / X</h6>
                                    <a href="@TempData.Peek("twitterUrl")"
                                       target="_blank"
                                       class="small">
                                        &#64;@TempData.Peek("authorName")
                                    </a>
                                </div>
                                <div class="col-5 text-end mt-sm-0 mt-2">
                                    <button class="btn btn-icon btn-outline-danger">
                                        <i class="icon-base bx bx-trash icon-md"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex mb-4 align-items-center">
                            <div class="flex-shrink-0">
                                <img src="~/img/icons/brands/instagram.png" alt="instagram" class="me-4" height="32" />
                            </div>
                            <div class="flex-grow-1 row">
                                <div class="col-7">
                                    <h6 class="mb-0">Instagram</h6>
                                    <a href="@TempData.Peek("instagramUrl")"
                                       target="_blank"
                                       class="small">
                                        &#64;@TempData.Peek("authorName")
                                    </a>
                                </div>
                                <div class="col-5 text-end mt-sm-0 mt-2">
                                    <button class="btn btn-icon btn-outline-danger">
                                        <i class="icon-base bx bx-trash icon-md"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex mb-4 align-items-center">
                            <div class="flex-shrink-0">
                                <img src="~/img/icons/brands/dribbble.png" alt="dribbble" class="me-4" height="32" />
                            </div>
                            <div class="flex-grow-1 row">
                                <div class="col-7">
                                    <h6 class="mb-0">Dribbble</h6>
                                    <small>Bağlı değil</small>
                                </div>
                                <div class="col-5 text-end mt-sm-0 mt-2">
                                    <button class="btn btn-icon btn-outline-secondary">
                                        <i class="icon-base bx bx-link icon-md"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <img src="~/img/icons/brands/behance.png" alt="behance" class="me-4" height="32" />
                            </div>
                            <div class="flex-grow-1 row align-items-center">
                                <div class="col-7">
                                    <h6 class="mb-0">Behance</h6>
                                    <small>Bağlı değil</small>
                                </div>
                                <div class="col-5 text-end">
                                    <button class="btn btn-icon btn-outline-secondary">
                                        <i class="icon-base bx bx-link icon-md"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- /Social Accounts -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
