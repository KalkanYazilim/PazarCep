@{
    ViewData["Title"] = "Hesap Ayarları - Hesap";
}

@section PageScripts {
    <script src="~/js/pages-account-settings-account.js"></script>
}

@* ************** Content ************** *@
<div class="row">
    <div class="col-md-12">
        <div class="nav-align-top">
            <ul class="nav nav-pills flex-column flex-md-row mb-6 gap-md-0 gap-2">
                <li class="nav-item">
                    <a class="nav-link active" href="javascript:void(0);">
                        <i class="icon-base bx bx-user icon-sm me-1_5"></i> Hesap
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="AccountSettingsNotifications">
                        <i class="icon-base bx bx-bell icon-sm me-1_5"></i> Bildirimler
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="AccountSettingsConnections">
                        <i class="icon-base bx bx-link-alt icon-sm me-1_5"></i> Bağlantılar
                    </a>
                </li>
            </ul>
        </div>

        <div class="card mb-6">
            <!-- Account -->
            <div class="card-body">
                <div class="d-flex align-items-start align-items-sm-center gap-6 pb-4 border-bottom">
                    <img src="~/img/avatars/1.png"
                         alt="user-avatar"
                         class="d-block w-px-100 h-px-100 rounded"
                         id="uploadedAvatar" />
                    <div class="button-wrapper">
                        <label for="upload" class="btn btn-primary me-3 mb-4" tabindex="0">
                            <span class="d-none d-sm-block">Yeni fotoğraf yükle</span>
                            <i class="icon-base bx bx-upload d-block d-sm-none"></i>
                            <input type="file"
                                   id="upload" name="upload"
                                   class="account-file-input"
                                   hidden
                                   accept="image/png, image/jpeg" />
                        </label>
                        <button type="button" class="btn btn-outline-secondary account-image-reset mb-4">
                            <i class="icon-base bx bx-reset d-block d-sm-none"></i>
                            <span class="d-none d-sm-block">Sıfırla</span>
                        </button>

                        <div>İzin verilen formatlar: JPG, GIF veya PNG. Maksimum boyut: 800 KB</div>
                    </div>
                </div>
            </div>

            <div class="card-body pt-4">
                <form id="formAccountSettings" method="POST" onsubmit="return false">
                    <div class="row g-6">
                        <div class="col-md-6">
                            <label for="firstName" class="form-label">Ad</label>
                            <input class="form-control"
                                   type="text"
                                   id="firstName"
                                   name="firstName"
                                   value="John"
                                   autofocus />
                        </div>
                        <div class="col-md-6">
                            <label for="lastName" class="form-label">Soyad</label>
                            <input class="form-control"
                                   type="text"
                                   name="lastName"
                                   id="lastName"
                                   value="Doe" />
                        </div>
                        <div class="col-md-6">
                            <label for="email" class="form-label">E-posta</label>
                            <input class="form-control"
                                   type="text"
                                   id="email"
                                   name="email"
                                   value="john.doe&#64;example.com"
                                   placeholder="ornek.kullanici&#64;eposta.com" />
                        </div>
                        <div class="col-md-6">
                            <label for="organization" class="form-label">Kurum / Şirket Adı</label>
                            <input type="text"
                                   class="form-control"
                                   id="organization"
                                   name="organization"
                                   value="@TempData.Peek("authorName")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="phoneNumber">Telefon Numarası</label>
                            <div class="input-group input-group-merge">
                                <span class="input-group-text">TR (+90)</span>
                                <input type="text"
                                       id="phoneNumber"
                                       name="phoneNumber"
                                       class="form-control"
                                       placeholder="5xx xxx xx xx" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label for="address" class="form-label">Adres</label>
                            <input type="text"
                                   class="form-control"
                                   id="address"
                                   name="address"
                                   placeholder="Adresinizi girin" />
                        </div>
                        <div class="col-md-6">
                            <label for="state" class="form-label">İl / Eyalet</label>
                            <input class="form-control"
                                   type="text"
                                   id="state"
                                   name="state"
                                   placeholder="Örn. Niğde" />
                        </div>
                        <div class="col-md-6">
                            <label for="zipCode" class="form-label">Posta Kodu</label>
                            <input type="text"
                                   class="form-control"
                                   id="zipCode"
                                   name="zipCode"
                                   placeholder="Posta kodu"
                                   maxlength="10" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" for="country">Ülke</label>
                            <select id="country" name="country" class="select2 form-select">
                                <option value="">Seçiniz</option>
                                <option value="Australia">Avustralya</option>
                                <option value="Bangladesh">Bangladeş</option>
                                <option value="Belarus">Belarus</option>
                                <option value="Brazil">Brezilya</option>
                                <option value="Canada">Kanada</option>
                                <option value="China">Çin</option>
                                <option value="France">Fransa</option>
                                <option value="Germany">Almanya</option>
                                <option value="India">Hindistan</option>
                                <option value="Indonesia">Endonezya</option>
                                <option value="Israel">İsrail</option>
                                <option value="Italy">İtalya</option>
                                <option value="Japan">Japonya</option>
                                <option value="Korea">Güney Kore</option>
                                <option value="Mexico">Meksika</option>
                                <option value="Philippines">Filipinler</option>
                                <option value="Russia">Rusya Federasyonu</option>
                                <option value="South Africa">Güney Afrika</option>
                                <option value="Thailand">Tayland</option>
                                <option value="Turkey" selected>Türkiye</option>
                                <option value="Ukraine">Ukrayna</option>
                                <option value="United Arab Emirates">Birleşik Arap Emirlikleri</option>
                                <option value="United Kingdom">Birleşik Krallık</option>
                                <option value="United States">Amerika Birleşik Devletleri</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="language" class="form-label">Dil</label>
                            <select id="language" name="language" class="select2 form-select">
                                <option value="">Dil Seçiniz</option>
                                <option value="tr" selected>Türkçe</option>
                                <option value="en">İngilizce</option>
                                <option value="fr">Fransızca</option>
                                <option value="de">Almanca</option>
                                <option value="pt">Portekizce</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="timeZones" class="form-label">Saat Dilimi</label>
                            <select id="timeZones" name="timeZones" class="select2 form-select">
                                <option value="">Saat dilimi seçin</option>
                                <option value="-12">(GMT-12:00) International Date Line West</option>
                                <option value="-11">(GMT-11:00) Midway Island, Samoa</option>
                                <option value="-10">(GMT-10:00) Hawaii</option>
                                <option value="-9">(GMT-09:00) Alaska</option>
                                <option value="-8">(GMT-08:00) Pacific Time (US & Canada)</option>
                                <option value="-8">(GMT-08:00) Tijuana, Baja California</option>
                                <option value="-7">(GMT-07:00) Arizona</option>
                                <option value="-7">(GMT-07:00) Chihuahua, La Paz, Mazatlan</option>
                                <option value="-7">(GMT-07:00) Mountain Time (US & Canada)</option>
                                <option value="-6">(GMT-06:00) Central America</option>
                                <option value="-6">(GMT-06:00) Central Time (US & Canada)</option>
                                <option value="-6">(GMT-06:00) Guadalajara, Mexico City, Monterrey</option>
                                <option value="-6">(GMT-06:00) Saskatchewan</option>
                                <option value="-5">(GMT-05:00) Bogota, Lima, Quito, Rio Branco</option>
                                <option value="-5">(GMT-05:00) Eastern Time (US & Canada)</option>
                                <option value="-5">(GMT-05:00) Indiana (East)</option>
                                <option value="-4">(GMT-04:00) Atlantic Time (Canada)</option>
                                <option value="-4">(GMT-04:00) Caracas, La Paz</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="currency" class="form-label">Para Birimi</label>
                            <select id="currency" name="currency" class="select2 form-select">
                                <option value="">Para birimi seçin</option>
                                <option value="try" selected>Türk Lirası (TRY)</option>
                                <option value="usd">Amerikan Doları (USD)</option>
                                <option value="euro">Euro (EUR)</option>
                                <option value="pound">Sterlin (GBP)</option>
                                <option value="bitcoin">Bitcoin (BTC)</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-6">
                        <button type="submit" class="btn btn-primary me-3">Değişiklikleri Kaydet</button>
                        <button type="reset" class="btn btn-outline-secondary">İptal</button>
                    </div>
                </form>
            </div>
            <!-- /Account -->
        </div>

        <div class="card">
            <h5 class="card-header">Hesabı Sil</h5>
            <div class="card-body">
                <div class="mb-6 col-12 mb-0">
                    <div class="alert alert-warning">
                        <h5 class="alert-heading mb-1">Hesabınızı silmek istediğinize emin misiniz?</h5>
                        <p class="mb-0">
                            Hesabınızı sildikten sonra geri dönüş yoktur. Lütfen bu işlemi onaylamadan önce emin olun.
                        </p>
                    </div>
                </div>
                <form id="formAccountDeactivation" onsubmit="return false">
                    <div class="form-check my-8 ms-2">
                        <input class="form-check-input"
                               type="checkbox"
                               name="accountActivation"
                               id="accountActivation" />
                        <label class="form-check-label" for="accountActivation">
                            Hesabımın devre dışı bırakılmasını onaylıyorum.
                        </label>
                    </div>
                    <button type="submit" class="btn btn-danger deactivate-account">
                        Hesabı Devre Dışı Bırak
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>
